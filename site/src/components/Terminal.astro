---
// Hero terminal — interactive command line.
---
<div class="term pcard" style="background:#070a08">
  <span class="corner tl"></span><span class="corner tr"></span>
  <span class="corner bl"></span><span class="corner br"></span>
  <div class="term-bar">
    <div class="lights"><i class="r"></i><i class="y"></i><i class="g"></i></div>
    <div class="title"><b>operator://</b>jonathan ~ session 0x42</div>
  </div>
  <div class="term-body" id="term-body">
    <div id="term-output">
      <span class="term-line dim">operator.os v2.6 — type <b style="color:var(--green)">help</b> to list commands</span>
      <span class="term-line"><span class="pmt">$</span> initialise_operator_profile</span>
      <span class="term-line dim">  ↳ ai_workflow_automation.......<span class="info">[ONLINE]</span></span>
      <span class="term-line dim">  ↳ voice_ai_stack...............<span class="info">[ONLINE]</span></span>
      <span class="term-line dim">  ↳ web3_operations..............<span class="info">[ONLINE]</span></span>
      <span class="term-line dim">  ↳ technical_dealmaking.........<span class="info">[ONLINE]</span></span>
      <span class="term-line"><span class="ok">  ▸ available_for_contracts</span></span>
    </div>
    <div class="term-input-row">
      <span class="pmt">$</span><input id="term-input" autocomplete="off" spellcheck="false" placeholder="try: help, projects, book, whoami" />
      <span class="cursor" id="term-cur"></span>
    </div>
  </div>
  <div class="term-foot">
    <span><span class="stat">●</span> connected · 142ms</span>
    <span>cpu <span class="progress" aria-hidden="true"><i class="on"></i><i class="on"></i><i class="on"></i><i class="on"></i><i class="on"></i><i></i><i></i><i></i></span></span>
    <span>mem ok</span>
  </div>
</div>

<script is:inline>
  (function () {
    const out = document.getElementById('term-output');
    const input = document.getElementById('term-input');
    const body = document.getElementById('term-body');
    if (!input || !out || !body) return;

    body.addEventListener('click', (e) => {
      if (e.target && e.target.tagName !== 'A') input.focus();
    });

    function write(html, cls) {
      const el = document.createElement('span');
      el.className = 'term-line ' + (cls || '');
      el.innerHTML = html;
      out.appendChild(el);
    }
    function writeBlock(lines) { lines.forEach((l) => write(l.t, l.c || '')); }
    function scroll() { body.scrollTop = body.scrollHeight; }

    const cmds = {
      help: () => writeBlock([
        { t: '<span class="dim">available commands:</span>' },
        { t: '  <b style="color:var(--green)">help</b>          show this list' },
        { t: '  <b style="color:var(--green)">whoami</b>        operator profile' },
        { t: '  <b style="color:var(--green)">ls /modules</b>   list capability modules' },
        { t: '  <b style="color:var(--green)">projects</b>      proof-of-work index' },
        { t: '  <b style="color:var(--green)">services</b>      ways to engage' },
        { t: '  <b style="color:var(--green)">writing</b>       recent notes' },
        { t: '  <b style="color:var(--green)">stack</b>         tools &amp; tech' },
        { t: '  <b style="color:var(--green)">contact</b>       direct channels' },
        { t: '  <b style="color:var(--green)">book</b>          start a project — opens contact form' },
        { t: '  <b style="color:var(--green)">status</b>        operator availability' },
        { t: '  <b style="color:var(--green)">clear</b>         clear screen' }
      ]),
      whoami: () => writeBlock([
        { t: '<span class="info">jonathan_abraham</span> · ai systems engineer' },
        { t: '  ↳ melbourne · au · us-tz overlap' },
        { t: '  ↳ full-stack + ai workflow + voice ai + web3 ops' },
        { t: '  ↳ commercial judgement / shipping over demos' }
      ]),
      'ls /modules': () => writeBlock([
        { t: '  <span class="ok">[01]</span> ai_workflow_automation/' },
        { t: '  <span class="ok">[02]</span> voice_ai_systems/' },
        { t: '  <span class="ok">[03]</span> web3_blockchain_ops/' },
        { t: '  <span class="ok">[04]</span> technical_dealmaking/' }
      ]),
      projects: () => writeBlock([
        { t: '  ▸ <a class="term-link" href="/projects/voice-ai-intake">voice_ai_intake</a>     · twilio · groq · streaming' },
        { t: '  ▸ <a class="term-link" href="/projects/insurance-workflow">insurance_workflow</a>  · documents · crm · review' },
        { t: '  ▸ <a class="term-link" href="/projects/web3-ops-agent">web3_ops_agent</a>      · treasury · governance · research' }
      ]),
      services: () => writeBlock([
        { t: '  ▸ <a class="term-link" href="/#services">ai_prototype_sprint</a>   — 10 business days' },
        { t: '  ▸ <a class="term-link" href="/#services">voice_ai_system_build</a> — scoped engagement' },
        { t: '  ▸ <a class="term-link" href="/#services">technical_contracting</a> — monthly retainer' },
        { t: '  ▸ <a class="term-link" href="/#services">founder_cto_support</a>   — advisory' }
      ]),
      writing: () => writeBlock([
        { t: '  ▸ <a class="term-link" href="/writing/voice-ai-after-demo">why production voice ai fails after the demo</a>' },
        { t: '  ▸ <a class="term-link" href="/writing/insurance-intake-design">designing an ai intake workflow for insurance</a>' },
        { t: '  ▸ <a class="term-link" href="/writing/ai-automation-operationalise">ai automation: easy to demo, hard to operationalise</a>' }
      ]),
      stack: () => writeBlock([
        { t: '<span class="dim">runtime:</span> node · python · typescript · postgres · redis' },
        { t: '<span class="dim">ai:</span>      openai · anthropic · groq · langgraph · llama.cpp' },
        { t: '<span class="dim">voice:</span>   twilio · livekit · deepgram · elevenlabs' },
        { t: '<span class="dim">web3:</span>    viem · ethers · the_graph · safe · tenderly' },
        { t: '<span class="dim">ops:</span>     railway · fly.io · cloudflare · supabase · sentry' }
      ]),
      contact: () => writeBlock([
        { t: '  ▸ email     <a class="term-link" href="mailto:hello@jonathanabraham.dev">hello@jonathanabraham.dev</a>' },
        { t: '  ▸ linkedin  /in/jonathan-abraham' },
        { t: '  ▸ github    /jonathanabraham' },
        { t: '  ▸ twitter   @jonabraham' }
      ]),
      book: () => {
        write('opening contact module...', 'info');
        setTimeout(() => {
          const el = document.getElementById('contact');
          if (el) window.scrollTo({ top: el.offsetTop - 70, behavior: 'smooth' });
          else window.location.href = '/#contact';
        }, 300);
      },
      status: () => writeBlock([
        { t: '<span class="ok">▸ available_for_contracts</span> — Q2 onward' },
        { t: '  current_focus: ai workflow · voice ai · web3 ops' },
        { t: '  response_sla: &lt; 24h · async-first' }
      ]),
      clear: () => { out.innerHTML = ''; }
    };
    cmds.ls = cmds['ls /modules'];
    cmds.cls = cmds.clear;
    cmds['?'] = cmds.help;

    function run(raw) {
      const cmd = raw.trim().toLowerCase();
      if (!cmd) return;
      write('<span class="pmt">$</span> ' + raw);
      if (cmds[cmd]) cmds[cmd]();
      else write('command not found: ' + raw + ' — type <b style="color:var(--green)">help</b>', 'warn');
      scroll();
    }

    const history = []; let hIdx = -1;
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const v = input.value;
        if (v.trim()) { history.unshift(v); hIdx = -1; }
        run(v);
        input.value = '';
      } else if (e.key === 'ArrowUp') {
        if (history.length) {
          hIdx = Math.min(hIdx + 1, history.length - 1);
          input.value = history[hIdx] || '';
          e.preventDefault();
        }
      } else if (e.key === 'ArrowDown') {
        if (hIdx > 0) { hIdx--; input.value = history[hIdx] || ''; }
        else { hIdx = -1; input.value = ''; }
        e.preventDefault();
      } else if (e.key === 'Tab') {
        e.preventDefault();
        const v = input.value.toLowerCase();
        const match = Object.keys(cmds).find((k) => k.startsWith(v) && v.length);
        if (match) input.value = match;
      }
    });
  })();
</script>
