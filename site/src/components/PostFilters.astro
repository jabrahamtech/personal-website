---
/**
 * PostFilters — topic browsing for the posts index.
 *
 * Cluster chips are the primary nav; type + sort are custom dropdowns (a
 * styled trigger + listbox so the menu matches the site, unlike a native
 * <select>). Self-contained: this component owns the filter UI *and* the
 * controller that filters/sorts #post-list and updates #post-status, so all
 * the behaviour lives in one place with its scoped styles.
 */
interface FilterOption { value: string; label?: string; count: number }
interface Props {
  contentTypeFilters: FilterOption[];
  clusterFilters: FilterOption[];
  total: number;
}
const { contentTypeFilters, clusterFilters, total } = Astro.props;
const showChips = clusterFilters.length > 1;

const typeOptions = [
  { value: 'all', label: `all types (${total})` },
  ...contentTypeFilters.map((f) => ({ value: f.value, label: `${f.label} (${f.count})` })),
];
const sortOptions = [
  { value: 'desc', label: 'newest first' },
  { value: 'asc', label: 'oldest first' },
];

const dropdowns = [
  { kind: 'type', defaultValue: 'all', labelText: 'type', options: typeOptions },
  { kind: 'order', defaultValue: 'desc', labelText: 'sort', options: sortOptions },
];
---
<div class="post-filters" id="post-filters" aria-label="filter posts">
  {showChips && (
    <div class="topic-chips" role="group" aria-label="Browse by topic">
      <button type="button" class="topic-chip is-active" data-filter-value="all" aria-pressed="true">All</button>
      {clusterFilters.map((c) => (
        <button
          type="button"
          class="topic-chip"
          data-filter-value={c.value}
          data-filter-label={c.value}
          aria-pressed="false"
        >{c.value}</button>
      ))}
    </div>
  )}

  <div class="filter-secondary">
    {dropdowns.map((dd) => (
      <div class={`filter-field${dd.kind === 'order' ? ' filter-field-order' : ''}`} data-dropdown data-kind={dd.kind} data-value={dd.defaultValue}>
        <span class="filter-label" id={`dd-${dd.kind}-label`}>{dd.labelText}</span>
        <button
          type="button"
          class="dd-trigger"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby={`dd-${dd.kind}-label dd-${dd.kind}-value`}
        >
          <span class="dd-value" id={`dd-${dd.kind}-value`}>{dd.options[0].label}</span>
          <span class="dd-caret" aria-hidden="true"></span>
        </button>
        <ul class="dd-list" role="listbox" aria-labelledby={`dd-${dd.kind}-label`} tabindex="-1" hidden>
          {dd.options.map((o, i) => (
            <li class="dd-option" role="option" data-value={o.value} aria-selected={i === 0 ? 'true' : 'false'}>{o.label}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<style>
  .post-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px 24px;
    margin: 4px 0 20px;
  }

  /* primary: topic chips (clusters) — sharp + mono to match the site */
  .topic-chips { display: flex; flex-wrap: wrap; gap: 8px }
  .topic-chip {
    font-family: var(--mono);
    font-size: 12.5px;
    letter-spacing: .02em;
    color: var(--ink-dim);
    background: var(--bg);
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    padding: 7px 13px;
    cursor: pointer;
    transition: color .12s ease, border-color .12s ease, background-color .12s ease;
  }
  .topic-chip:hover { color: var(--ink); border-color: var(--ink-mute) }
  .topic-chip.is-active {
    color: var(--green);
    border-color: var(--green-2);
    background: rgb(from var(--green) r g b / 0.09);
    font-weight: 600;
  }
  .topic-chip:focus-visible { outline: 2px solid var(--green-2); outline-offset: 2px }

  /* secondary: type + sort, as custom dropdowns */
  .filter-secondary { display: flex; flex-wrap: wrap; gap: 16px }
  .filter-field { position: relative; display: flex; flex-direction: column; gap: 5px }
  .filter-label {
    font-family: var(--mono);
    color: var(--ink-mute);
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  /* trigger — looks like a control; opens the styled listbox */
  .dd-trigger {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 150px;
    min-height: 36px;
    font-family: var(--mono);
    font-size: 12.5px;
    letter-spacing: .01em;
    color: var(--ink-dim);
    background-color: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    padding: 8px 12px;
    cursor: pointer;
    text-align: left;
    box-shadow: 0 1px 0 rgb(from var(--ink) r g b / 0.03);
    transition: color .14s ease, border-color .14s ease, box-shadow .14s ease;
  }
  .dd-value { flex: 1 }
  .dd-caret {
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    opacity: .7;
    transition: transform .14s ease;
  }
  .dd-trigger:hover { color: var(--ink); border-color: var(--ink-mute) }
  .dd-trigger:focus-visible {
    outline: none;
    color: var(--ink);
    border-color: var(--green-2);
    box-shadow: 0 0 0 3px rgb(from var(--green) r g b / 0.15);
  }
  [data-dropdown].is-open .dd-trigger { color: var(--ink); border-color: var(--ink-mute) }
  [data-dropdown].is-open .dd-caret { transform: rotate(180deg) }

  /* the menu that drops down — styled to match the site */
  .dd-list {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 40;
    margin: 6px 0 0;
    min-width: 100%;
    width: max-content;
    max-width: 320px;
    list-style: none;
    padding: 4px;
    background: var(--bg);
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.22);
    font-family: var(--mono);
    font-size: 12.5px;
  }
  .dd-list:focus-visible { outline: none }
  .dd-option {
    padding: 8px 10px;
    border-radius: var(--r-sm);
    color: var(--ink-dim);
    cursor: pointer;
    white-space: nowrap;
  }
  .dd-option:hover,
  .dd-option.is-active {
    background: rgb(from var(--green) r g b / 0.10);
    color: var(--green);
  }
  .dd-option[aria-selected="true"] { color: var(--green); font-weight: 600 }
  .dd-option[aria-selected="true"]::after { content: " ·"; opacity: .6 }

  @media (max-width: 560px) {
    .post-filters { flex-direction: column; align-items: stretch }
    .filter-secondary { width: 100% }
    .filter-field { flex: 1 }
    .dd-trigger { width: 100% }
    .dd-list { max-width: none }
  }
</style>

<script>
  function initPostFilters() {
    const root = document.getElementById('post-filters');
    const list = document.getElementById('post-list');
    const empty = document.getElementById('post-empty');
    const status = document.getElementById('post-status');
    if (!root || !list) return;

    const items = Array.from(list.querySelectorAll('li'));
    const chips = Array.from(root.querySelectorAll<HTMLElement>('.topic-chip'));
    const dropdowns = Array.from(root.querySelectorAll<HTMLElement>('[data-dropdown]'));
    const typeDd = dropdowns.find((d) => d.dataset.kind === 'type') || null;
    const orderDd = dropdowns.find((d) => d.dataset.kind === 'order') || null;
    const storageKey = 'ja_post_filter_v3';
    const total = items.length;

    /* ---------- custom dropdown widget ---------- */
    const ddValue = (dd: HTMLElement | null) => (dd ? dd.dataset.value || 'all' : 'all');
    function ddOptionLabel(dd: HTMLElement | null, value: string) {
      let label = value;
      dd && dd.querySelectorAll<HTMLElement>('.dd-option').forEach((o) => {
        if (o.dataset.value === value) label = (o.textContent || '').trim();
      });
      return label;
    }
    function ddSet(dd: HTMLElement | null, value: string, silent = false) {
      if (!dd) return;
      dd.dataset.value = value;
      const valEl = dd.querySelector<HTMLElement>('.dd-value');
      dd.querySelectorAll<HTMLElement>('.dd-option').forEach((o) => {
        const on = o.dataset.value === value;
        o.setAttribute('aria-selected', on ? 'true' : 'false');
        if (on && valEl) valEl.textContent = o.textContent;
      });
      if (!silent) dd.dispatchEvent(new CustomEvent('dd:change', { detail: { value } }));
    }
    function setActiveOption(listEl: HTMLElement, opt: HTMLElement | null) {
      listEl.querySelectorAll<HTMLElement>('.dd-option').forEach((o) => o.classList.toggle('is-active', o === opt));
      if (opt) opt.scrollIntoView({ block: 'nearest' });
    }
    function ddOpen(dd: HTMLElement, open: boolean) {
      const trigger = dd.querySelector<HTMLElement>('.dd-trigger');
      const listEl = dd.querySelector<HTMLElement>('.dd-list');
      if (!trigger || !listEl) return;
      if (open) {
        dropdowns.forEach((o) => { if (o !== dd) ddOpen(o, false); });
        listEl.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        dd.classList.add('is-open');
        const sel = listEl.querySelector<HTMLElement>('.dd-option[aria-selected="true"]')
          || listEl.querySelector<HTMLElement>('.dd-option');
        setActiveOption(listEl, sel);
        listEl.focus();
      } else {
        listEl.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        dd.classList.remove('is-open');
      }
    }
    dropdowns.forEach((dd) => {
      const trigger = dd.querySelector<HTMLElement>('.dd-trigger');
      const listEl = dd.querySelector<HTMLElement>('.dd-list');
      if (!trigger || !listEl) return;
      trigger.addEventListener('click', () => ddOpen(dd, listEl.hidden));
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') { e.preventDefault(); ddOpen(dd, true); }
      });
      listEl.querySelectorAll<HTMLElement>('.dd-option').forEach((opt) => {
        opt.addEventListener('click', () => { ddSet(dd, opt.dataset.value || 'all'); ddOpen(dd, false); trigger.focus(); });
      });
      listEl.addEventListener('keydown', (e) => {
        const opts = Array.from(listEl.querySelectorAll<HTMLElement>('.dd-option'));
        let idx = opts.findIndex((o) => o.classList.contains('is-active'));
        if (e.key === 'ArrowDown') { e.preventDefault(); setActiveOption(listEl, opts[Math.min(opts.length - 1, idx + 1)]); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); setActiveOption(listEl, opts[Math.max(0, idx - 1)]); }
        else if (e.key === 'Home') { e.preventDefault(); setActiveOption(listEl, opts[0]); }
        else if (e.key === 'End') { e.preventDefault(); setActiveOption(listEl, opts[opts.length - 1]); }
        else if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); const o = opts[idx]; if (o) { ddSet(dd, o.dataset.value || 'all'); ddOpen(dd, false); trigger.focus(); } }
        else if (e.key === 'Escape') { e.preventDefault(); ddOpen(dd, false); trigger.focus(); }
      });
    });
    document.addEventListener('click', (e) => {
      dropdowns.forEach((dd) => { if (!dd.contains(e.target as Node)) ddOpen(dd, false); });
    });

    /* ---------- list filter + sort controller ---------- */
    function sortItems(order: string) {
      const normalised = order === 'asc' ? 'asc' : 'desc';
      items.sort((a, b) => {
        const aDraft = a.getAttribute('data-draft') === '1';
        const bDraft = b.getAttribute('data-draft') === '1';
        if (aDraft !== bDraft) return aDraft ? 1 : -1;
        const aRaw = a.getAttribute('data-posted-time') || '';
        const bRaw = b.getAttribute('data-posted-time') || '';
        if (aRaw !== '' || bRaw !== '') {
          if (aRaw === '') return 1;
          if (bRaw === '') return -1;
          const diff = Number(aRaw) - Number(bRaw);
          if (diff !== 0) return normalised === 'desc' ? -diff : diff;
        }
        const at = a.getAttribute('data-title') || '';
        const bt = b.getAttribute('data-title') || '';
        return normalised === 'desc' ? at.localeCompare(bt) : bt.localeCompare(at);
      });
      items.forEach((li) => list.appendChild(li));
    }
    function labelFor(kind: string, value: string) {
      if (kind === 'cluster') {
        const chip = chips.find((c) => c.dataset.filterValue === value);
        return chip ? (chip.dataset.filterLabel || (chip.textContent || '').trim()) : value;
      }
      if (kind === 'type') return ddOptionLabel(typeDd, value).replace(/\s*\(\d+\)\s*$/, '').trim();
      return value;
    }
    function apply(kind: string, value: string, order: string) {
      const ord = order === 'asc' ? 'asc' : 'desc';
      sortItems(ord);
      let shown = 0;
      items.forEach((li) => {
        const types = (li.getAttribute('data-types') || '').split('|').filter(Boolean);
        const cluster = li.getAttribute('data-cluster') || '';
        const match = kind === 'all'
          || (kind === 'type' && types.indexOf(value) !== -1)
          || (kind === 'cluster' && cluster === value);
        (li as HTMLElement).hidden = !match;
        if (match) shown++;
      });
      // type + cluster are mutually exclusive; reset the inactive one (silently)
      ddSet(typeDd, kind === 'type' ? value : 'all', true);
      ddSet(orderDd, ord, true);
      chips.forEach((chip) => {
        const on = chip.dataset.filterValue === (kind === 'cluster' ? value : 'all');
        chip.classList.toggle('is-active', on);
        chip.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      if (empty) (empty as HTMLElement).hidden = shown !== 0;
      if (status) {
        // Keep the status line in flow (its space is reserved in CSS) and just
        // toggle the text, so going all -> filtered doesn't change page height.
        status.textContent = (kind !== 'all' && value !== 'all')
          ? 'Showing ' + shown + ' of ' + total + ' · ' + labelFor(kind, value)
          : '';
      }
      try { localStorage.setItem(storageKey, JSON.stringify({ kind, value, order: ord })); } catch (_) {}
    }

    // restore last filter, ignoring values that no longer exist
    let initial = { kind: 'all', value: 'all', order: 'desc' };
    try {
      const saved = JSON.parse(localStorage.getItem(storageKey) || 'null');
      const validAll = saved && saved.kind === 'all' && saved.value === 'all';
      const validType = saved && saved.kind === 'type' && typeDd
        && !!Array.from(typeDd.querySelectorAll<HTMLElement>('.dd-option')).find((o) => o.dataset.value === saved.value);
      const validCluster = saved && saved.kind === 'cluster'
        && chips.some((c) => c.dataset.filterValue === saved.value);
      if (validAll || validType || validCluster) {
        initial = { kind: saved.kind, value: saved.value, order: saved.order === 'asc' ? 'asc' : 'desc' };
      }
    } catch (_) {}
    apply(initial.kind, initial.value, initial.order);

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const value = chip.dataset.filterValue || 'all';
        apply(value === 'all' ? 'all' : 'cluster', value, ddValue(orderDd));
      });
    });
    if (typeDd) typeDd.addEventListener('dd:change', (e) => {
      const value = (e as CustomEvent).detail.value || 'all';
      apply(value === 'all' ? 'all' : 'type', value, ddValue(orderDd));
    });
    if (orderDd) orderDd.addEventListener('dd:change', () => {
      const activeChip = chips.find((c) => c.classList.contains('is-active') && c.dataset.filterValue !== 'all');
      if (activeChip) apply('cluster', activeChip.dataset.filterValue || 'all', ddValue(orderDd));
      else if (typeDd && ddValue(typeDd) !== 'all') apply('type', ddValue(typeDd), ddValue(orderDd));
      else apply('all', 'all', ddValue(orderDd));
    });

    /* Keep the page length constant across filters: reserve the full-list
       height (measured with every post shown) so hiding posts doesn't
       shrink the page or make the footer jump. Re-measured on resize and
       after fonts load so the reserved height stays accurate. */
    function reserveListHeight() {
      const states = items.map((li) => (li as HTMLElement).hidden);
      items.forEach((li) => { (li as HTMLElement).hidden = false; });
      list.style.minHeight = 'auto';
      const full = list.offsetHeight;
      items.forEach((li, i) => { (li as HTMLElement).hidden = states[i]; });
      list.style.minHeight = full + 'px';
    }
    reserveListHeight();
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(reserveListHeight);
    let resizeRaf = 0;
    window.addEventListener('resize', () => {
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(reserveListHeight);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initPostFilters);
  else initPostFilters();
</script>
