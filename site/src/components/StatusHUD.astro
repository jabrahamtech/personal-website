<aside id="status-hud" aria-label="system status">
  <div class="hud-bar" id="hud-bar">
    <span class="live"><i></i> SYSTEM_LIVE</span>
    <span class="toggle" id="hud-toggle">[ – ]</span>
  </div>
  <div class="hud-body">
    <div class="hud-row"><span class="k">local_time</span><span class="v green" id="hud-time">--:--:--</span></div>
    <div class="hud-row"><span class="k">location</span><span class="v">melbourne · au</span></div>
    <div class="hud-row"><span class="k">uptime</span><span class="v cyan" id="hud-uptime">—</span></div>
    <div class="hud-row"><span class="k">shipped_q</span><span class="v">07 systems</span></div>
    <div class="hud-row"><span class="k">response_sla</span><span class="v amber">&lt; 24h</span></div>
    <div class="hud-row"><span class="k">load</span><span class="v"><span class="hud-bars"><i class="on"></i><i class="on"></i><i class="on"></i><i class="on"></i><i class="on"></i><i></i><i></i><i></i></span></span></div>
    <div class="hud-row"><span class="k">status</span><span class="v green">accepting_briefs</span></div>
  </div>
</aside>

<script is:inline>
  (function () {
    const t = document.getElementById('hud-time');
    const u = document.getElementById('hud-uptime');
    const bar = document.getElementById('hud-bar');
    const hud = document.getElementById('status-hud');
    const toggle = document.getElementById('hud-toggle');
    const startMs = Date.parse('2022-03-01T00:00:00+11:00');
    const fmt = new Intl.DateTimeFormat('en-AU', {
      timeZone: 'Australia/Melbourne',
      hour12: false,
      hour: '2-digit', minute: '2-digit', second: '2-digit'
    });
    function tick() {
      const now = new Date();
      t.textContent = fmt.format(now);
      const diffDays = Math.floor((now.getTime() - startMs) / 86400000);
      const yrs = (diffDays / 365.25).toFixed(2);
      u.textContent = diffDays.toLocaleString() + 'd · ' + yrs + 'y';
    }
    tick();
    setInterval(tick, 1000);
    bar.addEventListener('click', () => {
      hud.classList.toggle('collapsed');
      toggle.textContent = hud.classList.contains('collapsed') ? '[ + ]' : '[ – ]';
    });
  })();
</script>
