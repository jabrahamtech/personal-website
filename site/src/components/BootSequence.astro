<div id="boot" aria-hidden="true"></div>

<!-- If JS is disabled the guard never runs, which would leave the #boot overlay
     covering the page indefinitely. Hide it for no-JS visitors so the
     underlying content is reachable. -->
<noscript><style>#boot{display:none}</style></noscript>

<script is:inline>
  (function () {
    var boot = document.getElementById('boot');
    if (!boot) return;
    var seen = sessionStorage.getItem('boot_seen');
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // The boot sequence is part of the engineer aesthetic and its lines read as
    // terminal chrome. This guard removes the overlay before paint for paper /
    // no-JS / reduced-motion / repeat visits; the animation and ALL its strings
    // live in /boot.js, loaded only for a genuine engineer-mode session, so they
    // never sit in the crawlable HTML document. Mode is set pre-paint on <html>.
    var mode = (document.documentElement.dataset.mode) || 'paper';
    if (seen || reduce || mode !== 'eng') { boot.remove(); return; }
    var s = document.createElement('script');
    s.src = '/boot.js';
    document.head.appendChild(s);
  })();
</script>
