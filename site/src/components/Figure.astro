---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  /** Force a specific intrinsic width/height for layout stability. */
  width?: number;
  height?: number;
}
const { src, alt, caption, width, height } = Astro.props;
const hasCaptionSlot = Astro.slots.has('caption');
const showCaption = !!caption || hasCaptionSlot;
---
<figure class="post-figure">
  <button type="button" class="post-figure-trigger" aria-haspopup="dialog" aria-label={`Open figure for closer look: ${alt}`}>
    <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
  </button>
  {showCaption && (
    <figcaption>
      {caption}
      <slot name="caption" />
    </figcaption>
  )}
  <dialog class="figure-zoom" aria-label={`${alt} — zoomable`}>
    <button type="button" class="figure-zoom-close" aria-label="close" data-zoom-close>×</button>
    <div class="figure-zoom-stage" data-zoom-stage>
      <img src={src} alt="" class="figure-zoom-img" data-zoom-img />
    </div>
    <p class="figure-zoom-hint" aria-hidden="true">scroll · pinch to zoom · drag to pan · esc to close</p>
  </dialog>
</figure>

<script>
  import Panzoom from '@panzoom/panzoom';

  // One initializer per page; iterates every figure that mounted.
  function init() {
    document.querySelectorAll<HTMLElement>('.post-figure').forEach((figure) => {
      if (figure.dataset.zoomBound === '1') return;
      figure.dataset.zoomBound = '1';

      const trigger = figure.querySelector<HTMLButtonElement>('.post-figure-trigger');
      const dialog = figure.querySelector<HTMLDialogElement>('.figure-zoom');
      const stage = figure.querySelector<HTMLElement>('[data-zoom-stage]');
      const img = figure.querySelector<HTMLImageElement>('[data-zoom-img]');
      const closeBtn = figure.querySelector<HTMLButtonElement>('[data-zoom-close]');
      if (!trigger || !dialog || !stage || !img || !closeBtn) return;

      let pz: ReturnType<typeof Panzoom> | null = null;
      let wheelHandler: ((e: WheelEvent) => void) | null = null;

      function open() {
        if (typeof dialog!.showModal === 'function') dialog!.showModal();
        else dialog!.setAttribute('open', '');
        // Init panzoom after the dialog is visible so layout dimensions are
        // settled. Constrain to "outside" so when zoomed in you can pan within
        // the image bounds but never drag it off the stage.
        pz = Panzoom(img!, {
          maxScale: 8,
          minScale: 1,
          startScale: 1,
          contain: 'outside',
          cursor: 'grab',
        });
        wheelHandler = (e) => pz!.zoomWithWheel(e);
        stage!.addEventListener('wheel', wheelHandler, { passive: false });
      }

      function cleanup() {
        if (wheelHandler) stage!.removeEventListener('wheel', wheelHandler);
        wheelHandler = null;
        if (pz) pz.destroy();
        pz = null;
      }

      trigger.addEventListener('click', open);
      closeBtn.addEventListener('click', () => dialog!.close());
      // Native ESC + .close() both fire the dialog's close event; tear panzoom
      // down there so we don't leak listeners across opens. Focus is auto-
      // restored to the trigger by the browser when a modal dialog closes.
      dialog.addEventListener('close', cleanup);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .post-figure-trigger {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: zoom-in;
  }
  .post-figure-trigger:focus-visible {
    outline: 2px solid var(--accent, #2BB8C4);
    outline-offset: 4px;
  }

  .figure-zoom {
    width: 100vw;
    width: 100dvw;
    height: 100vh;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: 0;
    background: rgba(11, 14, 12, 0.94);
    color: #f5e9d7;
    overflow: hidden;
  }
  .figure-zoom::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }
  .figure-zoom[open] {
    display: flex;
    flex-direction: column;
  }

  .figure-zoom-stage {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    touch-action: none;
  }

  .figure-zoom-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  .figure-zoom-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(245, 233, 215, 0.55);
    background: rgba(11, 14, 12, 0.85);
    color: #f5e9d7;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .figure-zoom-close:hover {
    background: rgba(245, 233, 215, 0.22);
    border-color: rgba(245, 233, 215, 0.85);
  }
  .figure-zoom-close:focus-visible {
    outline: 2px solid #2BB8C4;
    outline-offset: 2px;
  }

  .figure-zoom-hint {
    margin: 0;
    padding: 10px 16px 14px;
    text-align: center;
    font-family: var(--mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 12px;
    color: rgba(245, 233, 215, 0.65);
    letter-spacing: 0.02em;
  }
  @media (max-width: 540px) {
    .figure-zoom-hint { font-size: 11px; padding: 8px 12px 12px; }
    .figure-zoom-close { width: 40px; height: 40px; top: 10px; right: 10px; }
  }
</style>
