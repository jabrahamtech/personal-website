---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  /** Force a specific intrinsic width/height for layout stability. */
  width?: number;
  height?: number;
}
const { src, alt, caption, width, height } = Astro.props;
const hasCaptionSlot = Astro.slots.has('caption');
const showCaption = !!caption || hasCaptionSlot;
---
<figure class="post-figure">
  <button type="button" class="post-figure-trigger" aria-haspopup="dialog" aria-label={`Open figure for closer look: ${alt}`}>
    <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
  </button>
  {showCaption && (
    <figcaption>
      {caption}
      <slot name="caption" />
    </figcaption>
  )}
  <dialog class="figure-zoom" aria-label={`${alt} — zoomable`}>
    <div class="figure-zoom-toolbar">
      <button type="button" class="figure-zoom-btn figure-zoom-rotate" aria-label="rotate" data-zoom-rotate aria-pressed="false">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
      <button type="button" class="figure-zoom-btn figure-zoom-close" aria-label="close" data-zoom-close>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6l-12 12"/></svg>
      </button>
    </div>
    <div class="figure-zoom-stage" data-zoom-stage>
      <img src={src} alt="" class="figure-zoom-img" data-zoom-img />
    </div>
    <p class="figure-zoom-hint" aria-hidden="true">scroll · pinch to zoom · drag to pan · double-tap to reset · esc to close</p>
  </dialog>
</figure>

<script>
  import Panzoom from '@panzoom/panzoom';

  function init() {
    document.querySelectorAll<HTMLElement>('.post-figure').forEach((figure) => {
      if (figure.dataset.zoomBound === '1') return;
      figure.dataset.zoomBound = '1';

      const trigger = figure.querySelector<HTMLButtonElement>('.post-figure-trigger');
      const dialog = figure.querySelector<HTMLDialogElement>('.figure-zoom');
      const stage = figure.querySelector<HTMLElement>('[data-zoom-stage]');
      const img = figure.querySelector<HTMLImageElement>('[data-zoom-img]');
      const closeBtn = figure.querySelector<HTMLButtonElement>('[data-zoom-close]');
      const rotateBtn = figure.querySelector<HTMLButtonElement>('[data-zoom-rotate]');
      if (!trigger || !dialog || !stage || !img || !closeBtn || !rotateBtn) return;

      let pz: ReturnType<typeof Panzoom> | null = null;
      let wheelHandler: ((e: WheelEvent) => void) | null = null;
      let dblHandler: (() => void) | null = null;
      let rotated = false;

      // panzoom is left without `contain` on purpose: 'outside' forces the
      // image to cover the parent, which on portrait mobile (390-wide stage,
      // 700-tall) scales a 16:9 figure ~3× just to fill height. Without it,
      // the image starts at fit-to-viewport and the user opts into zoom.
      function mountPanzoom() {
        pz = Panzoom(img!, {
          maxScale: 8,
          minScale: 1,
          startScale: 1,
          step: 0.25,
          cursor: 'grab',
        });
        wheelHandler = (e) => pz!.zoomWithWheel(e);
        stage!.addEventListener('wheel', wheelHandler, { passive: false });
        dblHandler = () => pz!.reset();
        stage!.addEventListener('dblclick', dblHandler);
      }

      function unmountPanzoom() {
        if (wheelHandler) stage!.removeEventListener('wheel', wheelHandler);
        if (dblHandler) stage!.removeEventListener('dblclick', dblHandler);
        wheelHandler = null;
        dblHandler = null;
        if (pz) pz.destroy();
        pz = null;
        // panzoom.destroy() leaves its inline transform/cursor on the element.
        // Clear them so a stylesheet rule (e.g. .is-rotated's rotate(-90deg))
        // isn't shadowed by a stale inline matrix from the previous mount.
        img!.style.transform = '';
        img!.style.cursor = '';
        img!.style.touchAction = '';
        img!.style.userSelect = '';
      }

      function open() {
        if (typeof dialog!.showModal === 'function') dialog!.showModal();
        else dialog!.setAttribute('open', '');
        // Mount panzoom only in the un-rotated state. With rotation applied,
        // panzoom's inline transform=matrix(...) would override our CSS
        // rotate(-90deg). Letting rotation be a static "bigger view" mode
        // keeps drag directions intuitive — to zoom in, unrotate first.
        if (!rotated) mountPanzoom();
      }

      function close() {
        // dialog 'close' event will run cleanup; calling .close() here triggers it.
        dialog!.close();
      }

      function cleanup() {
        unmountPanzoom();
        // Reset rotation so the next open starts fresh.
        if (rotated) {
          rotated = false;
          img!.classList.remove('is-rotated');
          rotateBtn!.setAttribute('aria-pressed', 'false');
        }
      }

      // Rotating destroys panzoom (its inline transform would otherwise win
      // the cascade against our CSS rotate(-90deg)). The rotated state is a
      // static larger-view mode for portrait-viewing landscape figures.
      // Unrotating re-mounts panzoom so wheel/pinch zoom work again.
      function toggleRotate() {
        unmountPanzoom();
        rotated = !rotated;
        img!.classList.toggle('is-rotated', rotated);
        rotateBtn!.setAttribute('aria-pressed', rotated ? 'true' : 'false');
        if (!rotated) mountPanzoom();
      }

      trigger.addEventListener('click', open);
      closeBtn.addEventListener('click', close);
      rotateBtn.addEventListener('click', toggleRotate);
      // ESC + close button + click of close button all fire the dialog's
      // native close event — tear panzoom down once, here. Focus auto-
      // restores to the trigger when a modal dialog closes.
      dialog.addEventListener('close', cleanup);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .post-figure-trigger {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: zoom-in;
  }
  .post-figure-trigger:focus-visible {
    outline: 2px solid var(--accent, #2BB8C4);
    outline-offset: 4px;
  }

  .figure-zoom {
    width: 100vw;
    width: 100dvw;
    height: 100vh;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: 0;
    background: #0b0e0c;
    color: #f5e9d7;
    overflow: hidden;
  }
  .figure-zoom::backdrop {
    background: #0b0e0c;
  }
  .figure-zoom[open] {
    display: flex;
    flex-direction: column;
  }

  .figure-zoom-toolbar {
    position: absolute;
    top: max(12px, env(safe-area-inset-top));
    right: max(12px, env(safe-area-inset-right));
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  .figure-zoom-btn {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(245, 233, 215, 0.55);
    background: rgba(11, 14, 12, 0.85);
    color: #f5e9d7;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .figure-zoom-btn:hover {
    background: rgba(245, 233, 215, 0.18);
    border-color: rgba(245, 233, 215, 0.85);
  }
  .figure-zoom-btn:focus-visible {
    outline: 2px solid #2BB8C4;
    outline-offset: 2px;
  }
  .figure-zoom-rotate[aria-pressed="true"] {
    background: rgba(43, 184, 196, 0.22);
    border-color: rgba(43, 184, 196, 0.85);
    color: #2BB8C4;
  }
  /* Only useful when the viewport is portrait-ish enough that a landscape
     figure can't display at a useful size. Hide on wide landscape screens. */
  @media (min-aspect-ratio: 5/4) and (min-width: 720px) {
    .figure-zoom-rotate { display: none; }
  }

  .figure-zoom-stage {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: clamp(12px, 4vmin, 56px);
    /* Symmetric padding keeps the image centered. The toolbar is absolute-
       positioned at top-right with its own opaque pill backgrounds, so it
       overlays the image's corner cleanly without needing extra top padding. */
    touch-action: none;
  }

  /* Cap the displayed image at a sensible CSS size so it doesn't fill an
     ultrawide monitor edge-to-edge. The source PNGs are 3200×1800 (2× of
     1600×900), so capping CSS at 1600×900 still hands the browser 2× pixels
     on retina — the image stays sharp without ballooning. */
  .figure-zoom-img {
    max-width: min(100%, 1600px);
    max-height: min(100%, 900px);
    width: auto;
    height: auto;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 220ms ease;
    /* In the rotated state we explicitly want the layout box to be larger
       than its flex parent (so the visual rotation fills the viewport).
       Disable flex-shrink so max-width/max-height are the only constraints. */
    flex-shrink: 0;
  }
  /* Rotated state for portrait viewports of landscape figures. Absolutely
     positioned with explicit width (in viewport units) so the layout box
     can exceed the dialog's content area — otherwise the containing-block
     width caps auto-sized absolutes. The min() picks the larger of the
     two rotation-fit constraints: viewport height (becomes layout width)
     vs. viewport width × figure aspect (becomes layout width via aspect-
     ratio). Hardcoded 16/9 matches the current figures; switch to a JS-
     read of img.naturalWidth/Height if other aspects ship. */
  .figure-zoom-img.is-rotated {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-90deg);
    aspect-ratio: 16 / 9;
    width: min(calc(100dvh - 80px), calc((100dvw - 24px) * 16 / 9), 1600px);
    height: auto;
    max-width: none;
    max-height: none;
  }

  .figure-zoom-hint {
    /* Absolute-positioned overlay so the stage owns the full dialog height
       and the image is truly centered. Hint sits on the dark backdrop at
       the bottom; if the image is tall enough to overlap, it does so on
       a low-contrast strip and stays legible. */
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    padding: 10px 16px max(14px, env(safe-area-inset-bottom));
    text-align: center;
    font-family: var(--mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 12px;
    color: rgba(245, 233, 215, 0.65);
    letter-spacing: 0.02em;
    pointer-events: none;
  }
  @media (max-width: 540px) {
    .figure-zoom-hint { font-size: 10.5px; padding: 8px 12px max(12px, env(safe-area-inset-bottom)); }
    .figure-zoom-btn { width: 40px; height: 40px; }
    .figure-zoom-stage { padding: clamp(8px, 3vmin, 24px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .figure-zoom-img { transition: none; }
  }
</style>
