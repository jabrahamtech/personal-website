---
import { getCollection } from 'astro:content';
import ArticleCard from '../ArticleCard.astro';

const articles = (await getCollection('writing')).sort((a, b) => a.data.order - b.data.order);

const categories = [
  'all',
  'ai_workflow_automation',
  'voice_ai_in_production',
  'web3_operations',
  'engineering_to_business',
  'founder_notes',
];
---
<section id="writing" class="section reveal">
  <div class="wrap">
    <div class="section-head">
      <div class="prompt">&gt; ./writing</div>
      <h2 class="h">Writing</h2>
      <p class="sub">Technical notes and commercial lessons from building AI, voice, blockchain, and software systems.</p>
    </div>

    <div class="write-cats">
      {categories.map((cat, i) => (
        <button class={i === 0 ? 'active' : ''} data-cat={cat}>{cat}</button>
      ))}
    </div>

    <div class="grid-3" id="write-grid">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
    <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
  </div>
</section>

<script is:inline>
  (function () {
    const buttons = document.querySelectorAll('.write-cats button');
    const items = document.querySelectorAll('#write-grid .article');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-cat');
        items.forEach((it) => {
          if (cat === 'all' || it.getAttribute('data-cat') === cat) it.classList.remove('hide');
          else it.classList.add('hide');
        });
      });
    });
  })();
</script>
