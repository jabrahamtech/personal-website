---
const services = [
  {
    title: 'Production Readiness Sprint',
    price: '10 business days',
    priceMuted: false,
    body: "For teams with a working AI demo that's failing in production. I diagnose the failure modes — latency, state, hallucination, integration — rebuild the layer that needs rebuilding, and hand back a system you can run.",
    items: [
      'architecture review of current pipeline',
      'rebuild of the layer causing failures (usually state or streaming)',
      'observability and eval harness so the next regression is visible',
      'written handoff with the next 90 days prioritised',
      'one follow-up call 30 days in',
    ],
  },
  {
    title: 'Voice AI System Build',
    price: 'scoped engagement',
    priceMuted: true,
    body: 'Design and implementation support for voice AI flows: call handling, memory, summarisation, structured extraction, and backend integration.',
    items: [
      'telephony & streaming setup',
      'state, memory & interruptions',
      'structured output & CRM handoff',
      'observability & QA harness',
    ],
  },
  {
    title: 'Technical Contracting',
    price: 'monthly retainer',
    priceMuted: true,
    body: 'Hands-on software engineering across AI systems, backend development, integrations, automation, and production support.',
    items: [
      'backend & integration work',
      'AI feature delivery',
      'incident & production support',
      'documentation & handover',
    ],
  },
  {
    title: 'Founder / CTO Support',
    price: 'advisory',
    priceMuted: true,
    body: 'Technical strategy, scoping, architecture decisions, build-vs-buy analysis, and product execution support for early-stage teams.',
    items: [
      'architecture review & trade-offs',
      'build-vs-buy decisions',
      'roadmap & risk reduction',
      'hiring & vendor evaluation',
    ],
  },
];
---
<section id="services" class="section reveal">
  <div class="wrap">
    <div class="section-head">
      <div class="prompt">&gt; ./services</div>
      <h2 class="h">Ways to work together</h2>
      <p class="sub">Built for teams that need someone who can think commercially and ship technically.</p>
    </div>

    <div class="grid-2">
      {services.map((s) => (
        <div class="pcard svc">
          <span class="corner tl"></span><span class="corner br"></span>
          <div class="topline">
            <h3>{s.title}</h3>
            <span class={`price ${s.priceMuted ? 'muted' : ''}`}>{s.price}</span>
          </div>
          <p>{s.body}</p>
          <ul>{s.items.map((i) => <li>{i}</li>)}</ul>
        </div>
      ))}
    </div>

    <div style="margin-top:28px;display:flex;justify-content:center">
      <a href="#contact" class="btn btn-primary">▸ tell_me_what_youre_building <span class="arrow">→</span></a>
    </div>
    <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
  </div>
</section>
