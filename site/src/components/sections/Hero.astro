---
import Terminal from '../Terminal.astro';
---
<section id="home" class="section hero">
  <div class="wrap hero-grid">
    <div>
      <div class="badge-row">
        <span class="badge"><span class="b-dot"></span> available_for_contracts</span>
        <span class="badge"><span class="b-dot cyan"></span> melbourne · au</span>
        <span class="badge"><span class="b-dot amber"></span> us_timezone_overlap</span>
      </div>
      <h1 class="h">AI systems engineer for teams turning <span class="accent">messy operations</span> into working software.</h1>
      <p class="lead">I build practical AI, voice, and blockchain systems for founders, CTOs, and operators. From prototypes to production workflows — software that creates measurable business value, not demo-only theatre.</p>
      <div class="cta-row">
        <a href="#contact" class="btn btn-primary">▸ work_with_me <span class="arrow">→</span></a>
        <a href="#proof-of-work" class="btn btn-ghost">view_proof_of_work <span class="arrow">→</span></a>
      </div>
      <div class="trust">
        <span>contract</span><span class="sep">·</span>
        <span>consulting</span><span class="sep">·</span>
        <span>prototype sprints</span><span class="sep">·</span>
        <span>production support</span>
      </div>
    </div>
    <Terminal />
  </div>
  <div class="ascii-div" aria-hidden="true">▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒</div>
</section>
