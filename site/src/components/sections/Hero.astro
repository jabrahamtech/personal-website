---
import Terminal from '../Terminal.astro';
---
<section id="home" class="section hero">
  <div class="wrap hero-grid">
    <div>
      <div class="badge-row">
        <span class="badge"><span class="b-dot cyan"></span> melbourne · au</span>
        <span class="badge"><span class="b-dot amber"></span> us_timezone_overlap</span>
      </div>
      <h1 class="h">Founder-engineer building <span class="accent">production AI</span> for regulated industries.</h1>
      <p class="lead">I run an Australian insurtech (Brokerloop) and take on a small number of outside contracts where the work overlaps — voice AI, backend systems in Go, and AI workflows that have to survive compliance, latency, and real users on the phone. If you've got a demo that works and a production deployment that doesn't, that's usually where I come in.</p>
      <div class="cta-row">
        <a href="#contact" class="btn btn-primary">▸ work_with_me <span class="arrow">→</span></a>
        <a href="#proof-of-work" class="btn btn-ghost">view_proof_of_work <span class="arrow">→</span></a>
      </div>
      <div class="trust">
        <span>founder</span><span class="sep">·</span>
        <span>senior engineer</span><span class="sep">·</span>
        <span>contract work by referral</span>
      </div>
    </div>
    <Terminal />
  </div>
  <div class="ascii-div" aria-hidden="true">▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒</div>
</section>
