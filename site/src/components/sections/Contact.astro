---
const channels = [
  { glyph: '@',  label: 'email',    value: 'jabrahamtech@gmail.com',           href: 'mailto:jabrahamtech@gmail.com' },
  { glyph: 'in', label: 'linkedin', value: '/in/jonathan-abraham',             href: 'https://www.linkedin.com/in/jonathan-abraham', external: true },
  { glyph: '{}', label: 'github',   value: '/jabrahamtech',                    href: 'https://github.com/jabrahamtech', external: true },
];
const formAction = 'https://formsubmit.co/jabrahamtech@gmail.com';
---
<section id="contact" class="section reveal">
  <div class="wrap">
    <div class="section-head">
      <div class="prompt">&gt; ./contact</div>
      <h2 class="h">Start a conversation</h2>
      <p class="sub">If you're building something in AI, voice, blockchain, fintech, insurance, or workflow automation — send me a note.</p>
    </div>

    <div class="contact-grid">
      <form class="pcard form" id="contact-form" action={formAction} method="POST">
        <span class="corner tl"></span><span class="corner br"></span>
        <input type="hidden" name="_subject" value="new operator brief — jonathanabraham.dev" />
        <input type="hidden" name="_template" value="table" />
        <input type="text" name="_honey" style="display:none" />
        <div class="row2">
          <div class="field"><label>name <span>*</span></label><input required name="name" placeholder="ada lovelace" /></div>
          <div class="field"><label>email <span>*</span></label><input required type="email" name="email" placeholder="ada@startup.io" /></div>
        </div>
        <div class="row2">
          <div class="field"><label>company</label><input name="company" placeholder="acme labs" /></div>
          <div class="field">
            <label>budget_range <span style="color:var(--ink-mute)">(optional)</span></label>
            <select name="budget_range">
              <option>—</option>
              <option>&lt; $10k</option>
              <option>$10k – $25k</option>
              <option>$25k – $75k</option>
              <option>$75k+</option>
              <option>retainer</option>
            </select>
          </div>
        </div>
        <div class="field"><label>what are you building?</label><textarea name="building" placeholder="a voice AI for our insurance intake team..."></textarea></div>
        <div class="field"><label>what kind of help do you need?</label><textarea name="help_needed" placeholder="prototype sprint / build / advisory / production support..."></textarea></div>
        <div style="display:flex;justify-content:flex-end;margin-top:4px">
          <button type="submit" class="btn btn-primary" id="contact-submit">▸ send_message <span class="arrow">→</span></button>
        </div>
      </form>

      <div class="pcard channels">
        <span class="corner tl"></span><span class="corner br"></span>
        <h4 style="font-family:var(--mono);font-size:12px;color:var(--ink-mute);margin:0 0 4px;letter-spacing:.05em;text-transform:uppercase">// direct_channels</h4>
        {channels.map((c) => (
          <a class="ch-row" href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener' : undefined}>
            <div class="l"><span class="glyph">{c.glyph}</span><span>{c.label}</span></div>
            <div class="v">{c.value}</div>
          </a>
        ))}

        <div style="margin-top:12px;padding:14px;border:1px dashed var(--line-2);background:#0a0e0b">
          <div style="font-family:var(--mono);font-size:11.5px;color:var(--ink-mute);margin-bottom:8px">// availability</div>
          <div style="display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:13px">
            <span style="width:8px;height:8px;background:var(--green);box-shadow:0 0 8px var(--green);display:inline-block"></span>
            available for contracts — Q2 onward
          </div>
          <div style="font-family:var(--mono);font-size:11.5px;color:var(--ink-mute);margin-top:6px">us timezone overlap · async-first</div>
        </div>
      </div>
    </div>
  </div>
</section>
