---
// Bloomberg-style status strip, engineer-mode only. Its labels read as
// terminal/OS chrome, so neither the markup nor an inline script carries them:
// the builder and ALL its strings live in /status-strip.js (external — not read
// by scrapers for page descriptions), which injects the strip only once
// engineer mode is active. Paper / first-load visitors get a clean empty mount.
// The build marker is passed via data-build so it stays sourced from this file.
const buildSlug = 'a3f8c'; // bumped manually on substantive deploys
---
<div class="status-strip eng-only" id="status-strip" role="status" aria-label="system status" data-build={buildSlug}></div>
<script is:inline src="/status-strip.js" defer></script>
