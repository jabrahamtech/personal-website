---
type Link = { href: string; label: string };
const links: Link[] = [
  { href: '/#operating-system', label: 'work' },
  { href: '/#proof-of-work', label: 'proof' },
  { href: '/#services', label: 'services' },
  { href: '/#writing', label: 'writing' },
  { href: '/#contact', label: 'contact' },
];
---
<nav class="top">
  <div class="wrap row">
    <a class="brand" href="/">
      <span class="pixel-logo" aria-hidden="true">
        <i></i><i></i><i class="off"></i><i></i><i class="off"></i><i></i><i></i>
        <i></i><i class="off"></i><i></i><i></i><i></i><i class="off"></i><i></i>
        <i></i><i></i><i></i><i class="off"></i><i></i><i></i><i></i>
      </span>
      <span>jonathan_abraham<span style="color:var(--green)">.os</span></span>
    </a>
    <div class="nav-links" id="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div style="display:flex;align-items:center;gap:6px">
      <button class="nav-toggle" id="nav-toggle" aria-label="toggle menu" aria-expanded="false">
        <span class="bars"><i></i><i></i><i></i></span>
      </button>
      <a href="/#contact" class="nav-cta">▸ start_a_project</a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const t = document.getElementById('nav-toggle');
    const l = document.getElementById('nav-links');
    if (!t || !l) return;
    t.addEventListener('click', () => {
      const open = l.classList.toggle('open');
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    l.addEventListener('click', (e) => {
      if (e.target && e.target.tagName === 'A') {
        l.classList.remove('open');
        t.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
