---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/',       label: 'posts',    match: (p: string) => p === '/' || p.startsWith('/posts') },
  { href: '/about',  label: 'about',    match: (p: string) => p === '/about' },
  { href: '/rss.xml',label: 'rss',      match: () => false },
];
---
<nav class="top">
  <div class="wrap row">
    <a class="brand" href="/">jonathan_abraham<span class="accent">.os</span></a>
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} aria-current={l.match(path) ? 'page' : undefined}>{l.label}</a>
      ))}
    </div>
  </div>
</nav>
