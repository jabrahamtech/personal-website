---
import { getCollection, type CollectionEntry } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => {
    const ad = a.data.posted?.getTime() ?? 0;
    const bd = b.data.posted?.getTime() ?? 0;
    return bd - ad;
  });
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : null,
      older: i < posts.length - 1 ? posts[i + 1] : null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  newer: CollectionEntry<'posts'> | null;
  older: CollectionEntry<'posts'> | null;
}

const { post, newer, older } = Astro.props;
const { data } = post;
const { Content } = await post.render();

const metaRow: { label: string; value: string }[] = [];
if (data.posted) metaRow.push({ label: 'posted', value: data.posted.toISOString().slice(0, 10) });
else metaRow.push({ label: 'status', value: 'draft' });
if (data.readTime) metaRow.push({ label: 'read', value: data.readTime });

const siteOrigin = (Astro.site ?? new URL('https://jonathanabraham.dev')).toString().replace(/\/$/, '');
const url = `${siteOrigin}/posts/${post.slug}`;
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const blogPosting: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${url}#post`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  headline: data.title,
  description: data.summary,
  url,
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  keywords: data.tags.length ? data.tags.join(', ') : undefined,
  datePublished: data.posted?.toISOString(),
  dateModified: (data.posted ?? new Date()).toISOString(),
  image: {
    '@type': 'ImageObject',
    url: new URL(data.image?.src ?? '/og/default.png', siteOrigin + '/').toString(),
    caption: data.image?.alt ?? 'jonathan_abraham.os — shipping production AI for over 2 years',
  },
  ...(data.draft ? { creativeWorkStatus: 'Draft' } : {}),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Posts', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: data.title, item: url },
  ],
};
---
<DocLayout
  title={`${data.title} — Jonathan Abraham`}
  description={data.summary}
  promptPath={`./posts/${post.slug}`}
  crumbs={[
    { href: '/', label: '~' },
    { href: '/', label: 'posts' },
    { label: post.slug },
  ]}
  metaRow={metaRow}
  tags={data.tags}
  image={data.image?.src}
  imageAlt={data.image?.alt}
  pageType="article"
  publishedAt={data.posted}
  modifiedAt={data.posted}
  jsonLd={[blogPosting, breadcrumb]}
>
  {data.image && (
    <figure class="cover">
      <img src={data.image.src} alt={data.image.alt} loading="eager" />
    </figure>
  )}
  <Content />
  {(newer || older) && (
    <div class="pn" slot="footer">
      {newer ? (
        <a href={`/posts/${newer.slug}`}>
          <small>← newer</small>
          <span>{newer.data.title}</span>
        </a>
      ) : <span></span>}
      {older ? (
        <a class="next" href={`/posts/${older.slug}`}>
          <small>older →</small>
          <span>{older.data.title}</span>
        </a>
      ) : <span></span>}
    </div>
  )}
</DocLayout>
