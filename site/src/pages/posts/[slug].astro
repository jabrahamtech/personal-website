---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
import { stripImports } from '../../lib/postBody';
import { computeReadTime, computeWordCount } from '../../lib/readTime';
import { postUrl } from '../../lib/urls';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => {
    const ad = a.data.posted?.getTime() ?? 0;
    const bd = b.data.posted?.getTime() ?? 0;
    return bd - ad;
  });
  return posts.map((post, i) => {
    // Oldest gets 0x01 and the number grows as new posts ship — stable IDs
    // (renaming or reordering doesn't shuffle them backward over time).
    const postId = '0x' + (posts.length - i).toString(16).padStart(2, '0').toUpperCase();
    return {
      params: { slug: post.id },
      props: {
        post,
        postId,
        newer: i > 0 ? posts[i - 1] : null,
        older: i < posts.length - 1 ? posts[i + 1] : null,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<'posts'>;
  postId: string;
  newer: CollectionEntry<'posts'> | null;
  older: CollectionEntry<'posts'> | null;
}

const { post, postId, newer, older } = Astro.props;
const { data } = post;
const { Content, headings } = await render(post);

const sourcePath = `site/src/content/posts/${post.id}.mdx`;
const editUrl = `https://github.com/jabrahamtech/personal-website/edit/main/${sourcePath}`;

/* Meta-row composition:
   - "id" is always first (the hex post identifier).
   - "status: draft" surfaces whenever `data.draft` is true, even if a
     publication date is also set. Readers arriving at a draft URL
     (via Google, RSS preview, or a direct share) should see at a glance
     that the content isn't published. Previously this only showed up
     when `posted` was unset; with drafts now declaring `posted` dates,
     that pathway no longer fires.
   - "posted" / "pipeline" describe where the post is in the lifecycle. */
const metaRow: { label: string; value: string }[] = [];
metaRow.push({ label: 'id', value: postId });
if (data.draft) metaRow.push({ label: 'status', value: 'draft' });
if (data.posted) {
  metaRow.push({ label: 'posted', value: data.posted.toISOString().slice(0, 10) });
} else {
  metaRow.push({ label: 'pipeline', value: data.pipelineStatus.toLowerCase() });
}
if (data.cluster) metaRow.push({ label: 'cluster', value: data.cluster });
metaRow.push({ label: 'read', value: data.readTime ?? computeReadTime(post.body) });

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const url = postUrl(siteOrigin, post.id);
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

/* BlogPosting JSON-LD — datePublished is a required field on the
   schema.org/BlogPosting type per Google's Article structured-data spec,
   so emitting one for a draft without a `posted` date produces invalid
   markup that Search Console flags. Only build the BlogPosting node
   when the post actually has a publication date; drafts still ship
   the breadcrumb so the page's place in the site is unambiguous. */
const blogPosting: Record<string, unknown> | null = data.posted
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      '@id': `${url}#post`,
      mainEntityOfPage: { '@type': 'WebPage', '@id': url },
      headline: data.title,
      description: data.summary,
      url,
      inLanguage: 'en',
      isPartOf: { '@id': siteId },
      author: { '@id': personId },
      publisher: { '@id': personId },
      keywords: [...data.tags, ...data.contentTypes, data.cluster].filter(Boolean).join(', ') || undefined,
      wordCount: computeWordCount(post.body),
      articleBody: stripImports(post.body),
      articleSection: data.cluster || undefined,
      datePublished: data.posted.toISOString(),
      /* dateModified mirrors datePublished here because the site has no
         author-tracked modification date. Using `new Date()` would
         churn this field on every static build, which is noise SEO
         tooling treats as a real change. */
      dateModified: data.posted.toISOString(),
      image: {
        '@type': 'ImageObject',
        url: new URL(data.image?.src ?? '/og/default.png', siteOrigin + '/').toString(),
        caption: data.image?.alt ?? 'jonathan_abraham.os — shipping production AI for over 2 years',
      },
      ...(data.draft ? { creativeWorkStatus: 'Draft' } : {}),
    }
  : null;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Posts', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: data.title, item: url },
  ],
};

const jsonLdNodes: Record<string, unknown>[] = blogPosting
  ? [blogPosting, breadcrumb]
  : [breadcrumb];
---
<DocLayout
  title={`${data.title} — Jonathan Abraham`}
  description={data.summary}
  promptPath={`./posts/${post.id}`}
  crumbs={[
    { href: '/', label: '~' },
    { href: '/', label: 'posts' },
    { label: post.id },
  ]}
  metaRow={metaRow}
  tags={data.tags}
  image={data.image?.src}
  imageAlt={data.image?.alt}
  imageWidth={data.image?.width}
  imageHeight={data.image?.height}
  pageType="article"
  publishedAt={data.posted}
  modifiedAt={data.posted}
  jsonLd={jsonLdNodes}
  noindex={data.draft ?? false}
  postId={postId}
  headings={headings}
  editUrl={editUrl}
  sourcePath={sourcePath}
>
  {data.image && (
    <figure class="cover" slot="hero">
      <img
        src={data.image.src}
        alt={data.image.alt}
        width={data.image.width ?? 1600}
        height={data.image.height ?? 900}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      {data.image.caption && <figcaption>{data.image.caption}</figcaption>}
    </figure>
  )}
  <Content />
  {(newer || older) && (
    <div class="pn" slot="footer">
      {older ? (
        <a href={`/posts/${older.id}`}>
          <small>← older</small>
          <span>{older.data.title}</span>
        </a>
      ) : <span></span>}
      {newer ? (
        <a class="next" href={`/posts/${newer.id}`}>
          <small>newer →</small>
          <span>{newer.data.title}</span>
        </a>
      ) : <span></span>}
    </div>
  )}
</DocLayout>
