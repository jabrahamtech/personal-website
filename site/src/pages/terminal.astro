---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
---
<Base
  title="operator.training — production AI incident sim · Jonathan Abraham"
  description="operator.training — a short interactive sim. Two scenarios (voice AI intake, prop trading signal). Five stages each. Teaches production-AI patterns: triage, root cause, mitigation, verification, postmortem."
>
  <main id="content" class="wrap term-page">
    <header class="page-head">
      <h1 class="prompt">&gt; ./operator.training</h1>
      <p class="preamble">interactive incident sim — type <b>start</b> for the menu.</p>
    </header>

    <Terminal />

    <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
  </main>
</Base>
