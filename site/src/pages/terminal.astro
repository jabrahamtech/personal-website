---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
---
<Base
  title="Terminal — Jonathan Abraham"
  description="operator.training — an interactive incident-response sim that teaches production AI concepts."
>
  <main id="content" class="wrap term-page">
    <header class="page-head">
      <div class="prompt">&gt; ./terminal</div>
      <h1>Terminal</h1>
    </header>

    <p class="preamble">
      <b>operator.training v0.1</b> — a short interactive sim. you're paged at 2am: a voice ai is
      putting wrong customer addresses in call summaries. five stages: triage, root cause, mitigate,
      verify, postmortem. type <b>start</b> to begin · <b>help</b> for commands.
    </p>

    <Terminal />

    <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
  </main>
</Base>
