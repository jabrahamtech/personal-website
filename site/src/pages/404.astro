---
import Base from '../layouts/Base.astro';
const title = '404 — page not found';
---
<Base title={title} description="The page you're looking for doesn't exist." noindex>
  <main id="content" class="panic">
    <!-- engineer variant: original terminal-styled segfault. -->
    <div class="panic-eng eng-only">
      <div class="err">⚠ kernel: SIGNAL_NOT_FOUND · path resolves to /dev/null</div>
      <h1>404</h1>
      <p style="color:var(--ink-dim);max-width:560px;font-size:15px">
        the route you requested doesn't exist on this operator. could be a stale link, a moved page, or a typo in the address bar.
      </p>

      <div class="stack">
        <b>$ trace --route</b>
        ↳ requested:   <span style="color:var(--amber)" id="req-path">/unknown</span>
        ↳ resolver:    no_match
        ↳ index_db:    cold
        ↳ suggestion:  return_to_root
        ↳ status:      <span style="color:var(--red)">404</span> &nbsp; <span class="blink">█</span>
      </div>

      <div class="ascii" aria-hidden="true">▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒</div>

      <div class="actions">
        <a class="btn btn-primary" href="/">▸ return_to_root</a>
        <a class="btn" href="/about">about</a>
      </div>

      <div style="margin-top:36px;font-size:12px;color:var(--ink-mute)">
        // session continues. nothing was lost. press <b style="color:var(--green)">[esc]</b> or use the buttons above.
      </div>
    </div>

    <!-- paper variant: clean editorial 404. -->
    <div class="panic-paper paper-only">
      <p class="panic-eyebrow">404</p>
      <h1>This page doesn't exist.</h1>
      <p class="panic-lede">The link may be stale, the page may have moved, or there's a typo in the address. Press <kbd>esc</kbd> or use the links below to head back.</p>
      <p class="panic-meta">You requested: <span id="req-path-paper">/unknown</span></p>
      <div class="actions">
        <a class="btn btn-primary" href="/">Back to posts</a>
        <a class="btn" href="/about">About</a>
      </div>
    </div>
  </main>

  <script is:inline>
    const eng = document.getElementById('req-path');
    const paper = document.getElementById('req-path-paper');
    const path = location.pathname || '/unknown';
    if (eng) eng.textContent = path;
    if (paper) paper.textContent = path;
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') location.href = '/'; });
  </script>
</Base>
