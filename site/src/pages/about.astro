---
import Base from '../layouts/Base.astro';

const siteOrigin = (Astro.site ?? new URL('https://jonathanabraham.dev')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const url = `${siteOrigin}/about`;

const profileJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${url}#profile`,
  url,
  name: 'About Jonathan Abraham',
  inLanguage: 'en',
  mainEntity: { '@id': personId },
  about: { '@id': personId },
};

const description = 'About Jonathan Abraham — founder of Brokerloop, an Australian insurtech. Senior engineer building production voice AI, long-form intake flows, and Go-based backend AI infrastructure for regulated industries.';
---
<Base
  title="About — Jonathan Abraham"
  description={description}
  pageType="profile"
  jsonLd={profileJsonLd}
>
  <main id="content" class="wrap">
    <header class="page-head">
      <div class="prompt">&gt; ./about</div>
      <h1>About</h1>
    </header>

    <article class="prose">
      <figure class="avatar" aria-hidden="false">
        <img src="/about/avatar.svg" alt="Jonathan Abraham" width="200" height="200" loading="eager" />
      </figure>

      <p>I'm Jonathan. I'm the founder and senior engineer at <a href="#">Brokerloop</a>, an Australian insurtech building automation infrastructure for insurance brokers — voice AI, long-form intake flows, and Go-based backend systems integrated with the platforms brokers actually use.</p>

      <p>I came up through full-stack engineering and consulting, which is a less common path into AI than the research route. It means I think about commercial constraints first — pricing, scope, what a system has to do when it breaks at 2am — and treat the model as one component of a working system rather than the point of it.</p>

      <p>This site is mostly working notes — things I had to learn the hard way running production voice AI, building backend infrastructure in Go, and the operational shape of an insurtech where compliance, latency, and real callers all matter at once.</p>

      <p>Outside Brokerloop I take a small number of contracts each year, mostly in voice AI and backend AI infrastructure, for teams stuck in the gap between a working prototype and something that survives production. <strong>Contract work is by referral</strong>. If the work is in scope, the easiest way to reach me is <a href="mailto:jabrahamtech@gmail.com">email</a>.</p>

      <h2>Stack</h2>
      <ul>
        <li><strong>runtime:</strong> go · typescript · python · postgres · redis</li>
        <li><strong>ai:</strong> openai · anthropic · groq</li>
        <li><strong>voice:</strong> twilio · deepgram · pipecat · elevenlabs</li>
        <li><strong>ops:</strong> fly.io · cloudflare · supabase · sentry</li>
      </ul>

      <h2>Elsewhere</h2>
      <ul>
        <li><strong>email</strong> — <a href="mailto:jabrahamtech@gmail.com">jabrahamtech@gmail.com</a></li>
        <li><strong>github</strong> — <a href="https://github.com/jabrahamtech" rel="me">/jabrahamtech</a></li>
        <li><strong>linkedin</strong> — <a href="https://www.linkedin.com/in/jabrahamtech" rel="me">/in/jabrahamtech</a></li>
      </ul>
    </article>

    <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
  </main>
</Base>
