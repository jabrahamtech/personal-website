---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

const sorted = all.sort((a, b) => {
  const ad = a.data.posted?.getTime() ?? 0;
  const bd = b.data.posted?.getTime() ?? 0;
  if (ad !== bd) return bd - ad;
  return a.data.title.localeCompare(b.data.title);
});

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return 'draft';
}

const siteOrigin = (Astro.site ?? new URL('https://jonathanabraham.dev')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteOrigin}/#blog`,
  url: siteOrigin + '/',
  name: 'Jonathan Abraham — posts',
  description: 'Notes on production voice AI, AI workflow design, and backend AI infrastructure.',
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${siteOrigin}/posts/${p.slug}#post`,
    url: `${siteOrigin}/posts/${p.slug}`,
    headline: p.data.title,
    description: p.data.summary,
    datePublished: p.data.posted?.toISOString(),
    keywords: p.data.tags.join(', '),
    author: { '@id': personId },
    ...(p.data.draft ? { creativeWorkStatus: 'Draft' } : {}),
  })),
};

const description = 'Working notes from Jonathan Abraham on production voice AI, AI workflow design, and backend AI infrastructure for regulated industries (insurance, ops, voice).';
---
<Base
  title="Jonathan Abraham — production voice AI & AI infrastructure"
  description={description}
  jsonLd={blogJsonLd}
>
  <main id="content" class="wrap">
    <header class="page-head">
      <div class="prompt">&gt; ./posts</div>
    </header>

    <ul class="post-list">
      {sorted.map((post) => (
        <li>
          <a class="post-row" href={`/posts/${post.slug}`}>
            <div class="meta">
              <span>{fmt(post)}</span>
              {post.data.draft && <span class="draft">draft</span>}
              {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
              {post.data.tags.length > 0 && <><span class="sep">·</span><span class="tag">{post.data.tags.join(' · ')}</span></>}
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.summary}</p>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
