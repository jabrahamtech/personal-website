<script is:inline>
  // reveal-on-scroll
  (function () {
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  })();

  // writing category filter
  (function () {
    const buttons = document.querySelectorAll('.write-cats button');
    const items = document.querySelectorAll('#write-grid .article');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-cat');
        items.forEach((it) => {
          if (cat === 'all' || it.getAttribute('data-cat') === cat) it.classList.remove('hide');
          else it.classList.add('hide');
        });
      });
    });
  })();
</script>
