---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { postUrl } from '../lib/urls';
import FeaturedPosts from '../components/FeaturedPosts.astro';
import PostFilters from '../components/PostFilters.astro';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

function comparePosts(a: Post, b: Post, order: 'asc' | 'desc' = 'desc') {
  if (a.data.draft !== b.data.draft) return a.data.draft ? 1 : -1;

  const ad = a.data.posted?.getTime();
  const bd = b.data.posted?.getTime();
  if (ad !== undefined || bd !== undefined) {
    if (ad === undefined) return 1;
    if (bd === undefined) return -1;
    if (ad !== bd) return order === 'desc' ? bd - ad : ad - bd;
  }

  return order === 'desc'
    ? a.data.title.localeCompare(b.data.title)
    : b.data.title.localeCompare(a.data.title);
}

const sorted = [...all].sort((a, b) => comparePosts(a, b));

/* "latest" strip on the home page — the 3 most recent *published* posts
   that have a cover image, newest first. Drafts are excluded. */
const featured = [...all]
  .filter((p) => !p.data.draft && p.data.posted && p.data.image)
  .sort((a, b) =>
    b.data.posted!.getTime() - a.data.posted!.getTime()
    || a.data.title.localeCompare(b.data.title),
  )
  .slice(0, 3);

/* The featured posts appear only in the strip, not repeated in the list
   below — so the list is every other post, in the usual order. */
const featuredIds = new Set(featured.map((p) => p.id));
const listed = sorted.filter((p) => !featuredIds.has(p.id));

const contentTypeOrder = [
  'Learning Guides',
  'Technical Builds',
  'Case Studies',
  'Decision/Diagnostic Guides',
  'Playbooks',
] as const;

type ContentType = typeof contentTypeOrder[number];

// Labels are 1:1 with the schema values — the chip/filter text IS the
// category name. Kept as an explicit map so a chip label can be shortened
// later (e.g. on narrow viewports) without touching stored frontmatter.
const contentTypeLabels: Record<ContentType, string> = {
  'Learning Guides': 'Learning Guides',
  'Technical Builds': 'Technical Builds',
  'Case Studies': 'Case Studies',
  'Decision/Diagnostic Guides': 'Decision/Diagnostic Guides',
  'Playbooks': 'Playbooks',
};

const contentTypeFilters = contentTypeOrder
  .map((value) => ({
    kind: 'type',
    value,
    label: contentTypeLabels[value],
    count: listed.filter((p) => p.data.contentTypes.includes(value)).length,
  }))
  .filter((f) => f.count > 0);

const clusterFilters = Array.from(new Set(listed.map((p) => p.data.cluster).filter(Boolean)))
  .map((value) => ({
    kind: 'cluster',
    value: value as string,
    count: listed.filter((p) => p.data.cluster === value).length,
  }));

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return '';
}

function contentTypeLabel(value: string) {
  return contentTypeLabels[value as ContentType] ?? value;
}

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const defaultOg = {
  src: '/og/default.png',
  alt: 'jonathan_abraham.os — shipping production AI for over 2 years',
};

function imageFor(p: Post) {
  const img = p.data.image ?? defaultOg;
  return {
    '@type': 'ImageObject',
    url: new URL(img.src, siteOrigin + '/').toString(),
    caption: img.alt,
  };
}

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteOrigin}/#blog`,
  url: siteOrigin + '/',
  name: 'Jonathan Abraham — posts',
  description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  blogPost: sorted.filter((p) => !p.data.draft && p.data.posted).map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${postUrl(siteOrigin, p.id)}#post`,
    url: postUrl(siteOrigin, p.id),
    headline: p.data.title,
    description: p.data.summary,
    image: imageFor(p),
    datePublished: p.data.posted?.toISOString(),
    keywords: [...p.data.tags, ...p.data.contentTypes, p.data.cluster].filter(Boolean).join(', '),
    author: { '@id': personId },
  })),
};

const description = "Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Technical founder, Brokerloop.";
---
<Base
  title="Jonathan Abraham — building production-grade AI systems"
  description={description}
  jsonLd={blogJsonLd}
>
  <main id="content" class="wrap posts-index">
    <header class="page-head">
      <h1 class="prompt"><span class="ph-prefix eng-only">./</span>posts</h1>
    </header>

    {featured.length > 0 && <FeaturedPosts posts={featured} />}

    <PostFilters
      contentTypeFilters={contentTypeFilters}
      clusterFilters={clusterFilters}
      total={listed.length}
    />

    <p class="post-status" id="post-status" hidden aria-live="polite"></p>

    <ul class="post-list" id="post-list">
      {listed.map((post) => {
        const posted = fmt(post);
        return (
          <li
            data-types={post.data.contentTypes.join('|')}
            data-cluster={post.data.cluster ?? ''}
            data-posted-time={post.data.posted?.getTime() ?? ''}
            data-title={post.data.title}
            data-draft={post.data.draft ? '1' : '0'}
          >
            <a class="post-row" href={`/posts/${post.id}`}>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
              <div class="meta">
                {post.data.draft && <span class="draft">draft</span>}
                {posted && <span>{posted}</span>}
                {post.data.cluster && <span class="tag tag-cluster">{post.data.cluster}</span>}
                {post.data.contentTypes.map((type) => (
                  <span class="tag tag-cat" title={type}>{contentTypeLabel(type)}</span>
                ))}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <p class="post-empty" id="post-empty" hidden>nothing here in this filter — try another.</p>
  </main>

  <script is:inline>
    (function () {
      const root = document.getElementById('post-filters');
      const list = document.getElementById('post-list');
      const empty = document.getElementById('post-empty');
      const status = document.getElementById('post-status');
      if (!root || !list) return;
      const items = Array.from(list.querySelectorAll('li'));
      const chips = Array.from(root.querySelectorAll('.topic-chip'));
      const typeSelect = root.querySelector('#filter-type');
      const orderSelect = root.querySelector('[data-order-control]');
      const storageKey = 'ja_post_filter_v3';
      const total = items.length;

      function sortItems(order) {
        const normalised = order === 'asc' ? 'asc' : 'desc';
        items.sort((a, b) => {
          const aDraft = a.getAttribute('data-draft') === '1';
          const bDraft = b.getAttribute('data-draft') === '1';
          if (aDraft !== bDraft) return aDraft ? 1 : -1;

          const aRawDate = a.getAttribute('data-posted-time') || '';
          const bRawDate = b.getAttribute('data-posted-time') || '';
          const aHasDate = aRawDate !== '';
          const bHasDate = bRawDate !== '';
          if (aHasDate || bHasDate) {
            if (!aHasDate) return 1;
            if (!bHasDate) return -1;
            const diff = Number(aRawDate) - Number(bRawDate);
            if (diff !== 0) return normalised === 'desc' ? -diff : diff;
          }

          const at = a.getAttribute('data-title') || '';
          const bt = b.getAttribute('data-title') || '';
          return normalised === 'desc' ? at.localeCompare(bt) : bt.localeCompare(at);
        });
        items.forEach((li) => list.appendChild(li));
      }

      // Human label for the status line — chip label for clusters, the
      // option text (count stripped) for types.
      function labelFor(kind, value) {
        if (kind === 'cluster') {
          const chip = chips.find((c) => c.getAttribute('data-filter-value') === value);
          return chip ? (chip.getAttribute('data-filter-label') || chip.textContent.trim()) : value;
        }
        if (kind === 'type' && typeSelect) {
          const opt = Array.from(typeSelect.options).find((o) => o.value === value);
          return opt ? opt.textContent.replace(/\s*\(\d+\)\s*$/, '').trim() : value;
        }
        return value;
      }

      function apply(kind, value, order) {
        const normalisedOrder = order === 'asc' ? 'asc' : 'desc';
        sortItems(normalisedOrder);
        let shown = 0;
        items.forEach((li) => {
          const types = (li.getAttribute('data-types') || '').split('|').filter(Boolean);
          const cluster = li.getAttribute('data-cluster') || '';
          const match = kind === 'all'
            || (kind === 'type' && types.indexOf(value) !== -1)
            || (kind === 'cluster' && cluster === value);
          li.hidden = !match;
          if (match) shown++;
        });
        // Type and cluster are mutually exclusive: activating one resets the
        // other so the visible count is never ambiguous.
        if (typeSelect) typeSelect.value = kind === 'type' ? value : 'all';
        chips.forEach((chip) => {
          const target = kind === 'cluster' ? value : 'all';
          const on = chip.getAttribute('data-filter-value') === target;
          chip.classList.toggle('is-active', on);
          chip.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        if (orderSelect) orderSelect.value = normalisedOrder;
        if (empty) empty.hidden = shown !== 0;
        if (status) {
          if (kind !== 'all' && value !== 'all') {
            status.hidden = false;
            status.textContent = 'Showing ' + shown + ' of ' + total + ' · ' + labelFor(kind, value);
          } else {
            status.hidden = true;
            status.textContent = '';
          }
        }
        try { localStorage.setItem(storageKey, JSON.stringify({ kind, value, order: normalisedOrder })); } catch (_) {}
      }

      // Restore the last filter, ignoring values that no longer exist.
      let initial = { kind: 'all', value: 'all', order: 'desc' };
      try {
        const saved = JSON.parse(localStorage.getItem(storageKey) || 'null');
        const validAll = saved && saved.kind === 'all' && saved.value === 'all';
        const validType = saved && saved.kind === 'type' && typeSelect
          && Array.from(typeSelect.options).some((o) => o.value === saved.value);
        const validCluster = saved && saved.kind === 'cluster'
          && chips.some((c) => c.getAttribute('data-filter-value') === saved.value);
        if (validAll || validType || validCluster) {
          initial = { kind: saved.kind, value: saved.value, order: saved.order === 'asc' ? 'asc' : 'desc' };
        }
      } catch (_) {}
      apply(initial.kind, initial.value, initial.order);

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const value = chip.getAttribute('data-filter-value') || 'all';
          const order = orderSelect ? orderSelect.value : 'desc';
          apply(value === 'all' ? 'all' : 'cluster', value, order);
        });
      });
      if (typeSelect) {
        typeSelect.addEventListener('change', () => {
          const value = typeSelect.value || 'all';
          const order = orderSelect ? orderSelect.value : 'desc';
          apply(value === 'all' ? 'all' : 'type', value, order);
        });
      }
      if (orderSelect) {
        orderSelect.addEventListener('change', () => {
          const activeChip = chips.find((c) => c.classList.contains('is-active') && c.getAttribute('data-filter-value') !== 'all');
          let kind = 'all';
          let value = 'all';
          if (activeChip) { kind = 'cluster'; value = activeChip.getAttribute('data-filter-value'); }
          else if (typeSelect && typeSelect.value !== 'all') { kind = 'type'; value = typeSelect.value; }
          apply(kind, value, orderSelect.value);
        });
      }
    })();
  </script>
</Base>
