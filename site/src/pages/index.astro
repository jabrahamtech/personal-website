---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

const sorted = all.sort((a, b) => {
  const ad = a.data.posted?.getTime() ?? 0;
  const bd = b.data.posted?.getTime() ?? 0;
  if (ad !== bd) return bd - ad;
  return a.data.title.localeCompare(b.data.title);
});

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return 'draft';
}
---
<Base>
  <main id="content" class="wrap">
    <header class="page-head">
      <div class="prompt">&gt; ./posts</div>
    </header>

    <ul class="post-list">
      {sorted.map((post) => (
        <li>
          <a class="post-row" href={`/posts/${post.slug}`}>
            <div class="meta">
              <span>{fmt(post)}</span>
              {post.data.draft && <span class="draft">draft</span>}
              {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
              {post.data.tags.length > 0 && <><span class="sep">·</span><span class="tag">{post.data.tags.join(' · ')}</span></>}
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.summary}</p>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
