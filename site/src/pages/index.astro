---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
---
<Base>
  <main id="content">
    <!-- HERO -->
    <section id="home" class="section hero">
      <div class="wrap hero-grid">
        <div>
          <div class="badge-row">
            <span class="badge"><span class="b-dot"></span> available_for_contracts</span>
            <span class="badge"><span class="b-dot cyan"></span> melbourne · au</span>
            <span class="badge"><span class="b-dot amber"></span> us_timezone_overlap</span>
          </div>
          <h1 class="h">AI systems engineer for teams turning <span class="accent">messy operations</span> into working software.</h1>
          <p class="lead">I build practical AI, voice, and blockchain systems for founders, CTOs, and operators. From prototypes to production workflows — software that creates measurable business value, not demo-only theatre.</p>
          <div class="cta-row">
            <a href="#contact" class="btn btn-primary">▸ work_with_me <span class="arrow">→</span></a>
            <a href="#proof-of-work" class="btn btn-ghost">view_proof_of_work <span class="arrow">→</span></a>
          </div>
          <div class="trust">
            <span>contract</span><span class="sep">·</span>
            <span>consulting</span><span class="sep">·</span>
            <span>prototype sprints</span><span class="sep">·</span>
            <span>production support</span>
          </div>
        </div>
        <Terminal />
      </div>
      <div class="ascii-div" aria-hidden="true">▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒ ▒</div>
    </section>

    <!-- OPERATING SYSTEM -->
    <section id="operating-system" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./operating-system</div>
          <h2 class="h">Operating system</h2>
          <p class="sub">The way I work: manual insight, AI-assisted production, human-edited execution. Four modules, one operator.</p>
        </div>
        <div class="grid-4">
          <div class="pcard os-card">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="head">
              <div class="iconpix">
                <i style="background:var(--green)"></i><i></i><i style="background:var(--green)"></i><i></i><i style="background:var(--green)"></i>
                <i></i><i style="background:var(--green-2)"></i><i style="background:var(--green-2)"></i><i style="background:var(--green-2)"></i><i></i>
                <i style="background:var(--green)"></i><i style="background:var(--green-2)"></i><i style="background:var(--green)"></i><i style="background:var(--green-2)"></i><i style="background:var(--green)"></i>
                <i></i><i style="background:var(--green-2)"></i><i style="background:var(--green-2)"></i><i style="background:var(--green-2)"></i><i></i>
                <i style="background:var(--green)"></i><i></i><i style="background:var(--green)"></i><i></i><i style="background:var(--green)"></i>
              </div>
              <span class="num">/01</span>
            </div>
            <h3>AI Workflow Automation</h3>
            <p>Document extraction, email triage, CRM automation, quote intake, internal copilots, human-in-the-loop review, audit logs.</p>
            <div class="tag-row"><span class="tag">extraction</span><span class="tag">CRM</span><span class="tag">copilots</span></div>
          </div>

          <div class="pcard os-card">
            <span class="corner tr"></span><span class="corner bl"></span>
            <div class="head">
              <div class="iconpix">
                <i></i><i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i><i></i>
                <i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i>
                <i></i><i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i><i></i>
                <i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i>
                <i></i><i style="background:var(--cyan)"></i><i></i><i style="background:var(--cyan)"></i><i></i>
              </div>
              <span class="num">/02</span>
            </div>
            <h3>Voice AI Systems</h3>
            <p>Twilio, Groq, streaming responses, interruptions, memory, call summarisation, structured output, insurance intake.</p>
            <div class="tag-row"><span class="tag">twilio</span><span class="tag">groq</span><span class="tag">streaming</span></div>
          </div>

          <div class="pcard os-card">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="head">
              <div class="iconpix">
                <i></i><i></i><i style="background:var(--purple)"></i><i></i><i></i>
                <i></i><i style="background:var(--purple)"></i><i style="background:var(--purple)"></i><i style="background:var(--purple)"></i><i></i>
                <i style="background:var(--purple)"></i><i style="background:var(--purple)"></i><i style="background:var(--green)"></i><i style="background:var(--purple)"></i><i style="background:var(--purple)"></i>
                <i></i><i style="background:var(--purple)"></i><i style="background:var(--purple)"></i><i style="background:var(--purple)"></i><i></i>
                <i></i><i></i><i style="background:var(--purple)"></i><i></i><i></i>
              </div>
              <span class="num">/03</span>
            </div>
            <h3>Web3 / Blockchain Ops</h3>
            <p>Treasury reporting, wallet monitoring, DAO tooling, governance summaries, token research agents, operational dashboards.</p>
            <div class="tag-row"><span class="tag">treasury</span><span class="tag">DAO</span><span class="tag">on-chain</span></div>
          </div>

          <div class="pcard os-card">
            <span class="corner tr"></span><span class="corner bl"></span>
            <div class="head">
              <div class="iconpix">
                <i style="background:var(--amber)"></i><i style="background:var(--amber)"></i><i></i><i style="background:var(--amber)"></i><i style="background:var(--amber)"></i>
                <i style="background:var(--amber)"></i><i></i><i></i><i></i><i style="background:var(--amber)"></i>
                <i></i><i></i><i style="background:var(--amber)"></i><i></i><i></i>
                <i style="background:var(--amber)"></i><i></i><i></i><i></i><i style="background:var(--amber)"></i>
                <i style="background:var(--amber)"></i><i style="background:var(--amber)"></i><i></i><i style="background:var(--amber)"></i><i style="background:var(--amber)"></i>
              </div>
              <span class="num">/04</span>
            </div>
            <h3>Technical Deal-Making</h3>
            <p>Scoping prototypes, pricing sprints, reducing implementation risk, translating technical work into commercial outcomes.</p>
            <div class="tag-row"><span class="tag">scoping</span><span class="tag">pricing</span><span class="tag">strategy</span></div>
          </div>
        </div>
        <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
      </div>
    </section>

    <!-- PROOF OF WORK -->
    <section id="proof-of-work" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./proof-of-work</div>
          <h2 class="h">Proof-of-work</h2>
          <p class="sub">Selected systems, prototypes, and technical breakdowns. Some client work is confidential — public examples focus on architecture, patterns, and transferable lessons.</p>
        </div>

        <div class="grid-3">
          <article class="pcard proj">
            <span class="corner tl"></span><span class="corner tr"></span>
            <div class="proj-vis">
              <div class="vis-grid"></div>
              <div class="vis-label">node_graph.svg</div>
              <svg viewBox="0 0 320 200" style="position:absolute;inset:0;width:100%;height:100%" aria-hidden="true">
                <g stroke="#46c463" stroke-width="1.2" fill="none" opacity=".7">
                  <path d="M40 60 L120 60 L120 100 L200 100 L200 60 L280 60"/>
                  <path d="M120 100 L120 140 L200 140 L200 100"/>
                  <path d="M40 60 L40 140 L120 140"/>
                </g>
                <g fill="#0a0e0b" stroke="#7dff8a" stroke-width="1.2">
                  <rect x="22" y="48" width="36" height="24"/>
                  <rect x="102" y="48" width="36" height="24"/>
                  <rect x="182" y="48" width="36" height="24"/>
                  <rect x="262" y="48" width="36" height="24"/>
                  <rect x="102" y="128" width="36" height="24"/>
                  <rect x="182" y="128" width="36" height="24"/>
                  <rect x="22" y="128" width="36" height="24"/>
                </g>
                <g fill="#7dff8a" font-family="JetBrains Mono" font-size="7">
                  <text x="28" y="63">CALL</text>
                  <text x="108" y="63">ASR</text>
                  <text x="188" y="63">LLM</text>
                  <text x="268" y="63">TTS</text>
                  <text x="105" y="143">MEM</text>
                  <text x="184" y="143">SUM</text>
                  <text x="26" y="143">LOG</text>
                </g>
              </svg>
              <div class="vis-tag">v0.4.2 · ok</div>
            </div>
            <div class="proj-body">
              <h3>Voice AI Intake System</h3>
              <div class="tags"><span>Voice AI</span><span>Twilio</span><span>Groq</span><span>Streaming</span><span>Memory</span></div>
              <p>A node-based voice AI flow that collects structured information from business calls, handles interruptions, summarises conversations, and maintains context across turns.</p>
              <a class="pcta" href="/projects/voice-ai-intake">view_breakdown <span>→</span></a>
            </div>
          </article>

          <article class="pcard proj">
            <span class="corner tl"></span><span class="corner tr"></span>
            <div class="proj-vis">
              <div class="vis-grid"></div>
              <div class="vis-label">workflow.dag</div>
              <svg viewBox="0 0 320 200" style="position:absolute;inset:0;width:100%;height:100%" aria-hidden="true">
                <g stroke="#6ee7ff" stroke-width="1.2" fill="none" opacity=".75">
                  <path d="M30 100 L90 60"/><path d="M30 100 L90 100"/><path d="M30 100 L90 140"/>
                  <path d="M120 60 L180 100"/><path d="M120 100 L180 100"/><path d="M120 140 L180 100"/>
                  <path d="M210 100 L270 60"/><path d="M210 100 L270 140"/>
                </g>
                <g fill="#0a0e0b" stroke="#6ee7ff" stroke-width="1.2">
                  <rect x="14" y="88" width="32" height="24"/>
                  <rect x="92" y="48" width="32" height="24"/>
                  <rect x="92" y="88" width="32" height="24"/>
                  <rect x="92" y="128" width="32" height="24"/>
                  <rect x="180" y="88" width="32" height="24"/>
                  <rect x="270" y="48" width="32" height="24"/>
                  <rect x="270" y="128" width="32" height="24"/>
                </g>
                <g fill="#6ee7ff" font-family="JetBrains Mono" font-size="7">
                  <text x="20" y="103">INBOX</text>
                  <text x="98" y="63">EMAIL</text>
                  <text x="100" y="103">PDF</text>
                  <text x="100" y="143">NOTE</text>
                  <text x="184" y="103">EXTRACT</text>
                  <text x="276" y="63">CRM</text>
                  <text x="274" y="143">REVIEW</text>
                </g>
              </svg>
              <div class="vis-tag" style="color:var(--cyan)">v1.2 · prod</div>
            </div>
            <div class="proj-body">
              <h3>AI Insurance Workflow Automation</h3>
              <div class="tags"><span>AI</span><span>Documents</span><span>CRM</span><span>Workflow</span></div>
              <p>A practical workflow turning messy quote emails, PDFs, and intake notes into structured tasks, missing-information checks, and CRM-ready data.</p>
              <a class="pcta" href="/projects/insurance-workflow">view_architecture <span>→</span></a>
            </div>
          </article>

          <article class="pcard proj">
            <span class="corner tl"></span><span class="corner tr"></span>
            <div class="proj-vis">
              <div class="vis-grid"></div>
              <div class="vis-label">treasury.live</div>
              <svg viewBox="0 0 320 200" style="position:absolute;inset:0;width:100%;height:100%" aria-hidden="true">
                <g stroke="#c79bff" stroke-width="1" opacity=".5">
                  <path d="M0 150 L40 140 L80 145 L120 120 L160 130 L200 95 L240 110 L280 80 L320 90" fill="none"/>
                </g>
                <g stroke="#7dff8a" stroke-width="1.2" fill="none">
                  <path d="M0 130 L40 120 L80 100 L120 110 L160 80 L200 70 L240 60 L280 45 L320 50"/>
                </g>
                <g fill="#0a0e0b" stroke="#c79bff" stroke-width="1">
                  <rect x="20" y="30" width="80" height="30"/>
                  <rect x="220" y="30" width="80" height="30"/>
                </g>
                <g fill="#c79bff" font-family="JetBrains Mono" font-size="7">
                  <text x="28" y="42">WALLET 0xA1..</text>
                  <text x="28" y="54">$1.24M  +2.1%</text>
                  <text x="228" y="42">DAO_VOTES</text>
                  <text x="228" y="54">12 OPEN  3 NEW</text>
                </g>
                <g fill="#7dff8a" font-family="JetBrains Mono" font-size="7">
                  <text x="20" y="180">▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌▌</text>
                </g>
              </svg>
              <div class="vis-tag" style="color:var(--purple)">v0.3 · alpha</div>
            </div>
            <div class="proj-body">
              <h3>Web3 Operations Agent</h3>
              <div class="tags"><span>Web3</span><span>Wallets</span><span>Treasury</span><span>Research</span></div>
              <p>An AI-assisted operations system for monitoring wallets, summarising governance activity, tracking treasury changes, and producing structured research updates.</p>
              <a class="pcta" href="/projects/web3-ops-agent">view_concept <span>→</span></a>
            </div>
          </article>
        </div>

        <p style="font-family:var(--mono);font-size:12.5px;color:var(--ink-mute);margin-top:22px;border-left:2px solid var(--line-2);padding-left:12px">
          // some client and employer work is confidential. public examples focus on architecture, patterns, and transferable lessons.
        </p>
        <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./services</div>
          <h2 class="h">Ways to work together</h2>
          <p class="sub">Built for teams that need someone who can think commercially and ship technically.</p>
        </div>

        <div class="grid-2">
          <div class="pcard svc">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="topline"><h3>AI Prototype Sprint</h3><span class="price">10 business days</span></div>
            <p>A focused sprint to design and build a working AI workflow prototype around a specific operational bottleneck.</p>
            <ul>
              <li>workflow mapping &amp; bottleneck triage</li>
              <li>functional prototype build</li>
              <li>architecture diagram &amp; data flow</li>
              <li>implementation roadmap</li>
              <li>risk &amp; human-review notes</li>
            </ul>
          </div>

          <div class="pcard svc">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="topline"><h3>Voice AI System Build</h3><span class="price muted">scoped engagement</span></div>
            <p>Design and implementation support for voice AI flows: call handling, memory, summarisation, structured extraction, and backend integration.</p>
            <ul>
              <li>telephony &amp; streaming setup</li>
              <li>state, memory &amp; interruptions</li>
              <li>structured output &amp; CRM handoff</li>
              <li>observability &amp; QA harness</li>
            </ul>
          </div>

          <div class="pcard svc">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="topline"><h3>Technical Contracting</h3><span class="price muted">monthly retainer</span></div>
            <p>Hands-on software engineering across AI systems, backend development, integrations, automation, and production support.</p>
            <ul>
              <li>backend &amp; integration work</li>
              <li>AI feature delivery</li>
              <li>incident &amp; production support</li>
              <li>documentation &amp; handover</li>
            </ul>
          </div>

          <div class="pcard svc">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="topline"><h3>Founder / CTO Support</h3><span class="price muted">advisory</span></div>
            <p>Technical strategy, scoping, architecture decisions, build-vs-buy analysis, and product execution support for early-stage teams.</p>
            <ul>
              <li>architecture review &amp; trade-offs</li>
              <li>build-vs-buy decisions</li>
              <li>roadmap &amp; risk reduction</li>
              <li>hiring &amp; vendor evaluation</li>
            </ul>
          </div>
        </div>

        <div style="margin-top:28px;display:flex;justify-content:center">
          <a href="#contact" class="btn btn-primary">▸ tell_me_what_youre_building <span class="arrow">→</span></a>
        </div>
        <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
      </div>
    </section>

    <!-- WRITING -->
    <section id="writing" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./writing</div>
          <h2 class="h">Writing</h2>
          <p class="sub">Technical notes and commercial lessons from building AI, voice, blockchain, and software systems.</p>
        </div>

        <div class="write-cats">
          <button class="active" data-cat="all">all</button>
          <button data-cat="ai_workflow_automation">ai_workflow_automation</button>
          <button data-cat="voice_ai_in_production">voice_ai_in_production</button>
          <button data-cat="web3_operations">web3_operations</button>
          <button data-cat="engineering_to_business">engineering_to_business</button>
          <button data-cat="founder_notes">founder_notes</button>
        </div>

        <div class="grid-3" id="write-grid">
          <article class="pcard article" data-cat="voice_ai_in_production">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="meta"><span class="cat">[voice_ai_in_production]</span><span>~ 7 min</span></div>
            <h3>Why production voice AI fails after the demo</h3>
            <p>The hard part is not the voice. It is state, interruptions, memory, and handoff.</p>
            <a class="read" href="/writing/voice-ai-after-demo">read_note <span>→</span></a>
          </article>

          <article class="pcard article" data-cat="ai_workflow_automation">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="meta"><span class="cat">[ai_workflow_automation]</span><span>~ 9 min</span></div>
            <h3>How I would design an AI intake workflow for insurance brokers</h3>
            <p>From messy emails and PDFs to structured quote data, missing-info checks, and human review.</p>
            <a class="read" href="/writing/insurance-intake-design">read_note <span>→</span></a>
          </article>

          <article class="pcard article" data-cat="engineering_to_business">
            <span class="corner tl"></span><span class="corner br"></span>
            <div class="meta"><span class="cat">[engineering_to_business]</span><span>~ 6 min</span></div>
            <h3>AI automation is easy to demo and hard to operationalise</h3>
            <p>Why serious teams need audit logs, retries, permissions, and workflow design — not just prompts.</p>
            <a class="read" href="/writing/ai-automation-operationalise">read_note <span>→</span></a>
          </article>
        </div>
        <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./about</div>
          <h2 class="h">About Jonathan</h2>
        </div>

        <div class="about-grid">
          <div class="about">
            <p>I'm a software engineer and AI solutions consultant based in Melbourne. I work across full-stack software, backend systems, AI workflow automation, voice AI, IoT, and blockchain operations.</p>
            <p>My edge is combining technical execution with commercial judgement. I care less about flashy demos and more about systems that survive real users, messy data, business constraints, and production risk.</p>
            <p>I'm especially interested in working with founders, CTOs, and operators building in AI, fintech, insurance, Web3, and workflow-heavy businesses.</p>
          </div>
          <div class="pcard creds">
            <span class="corner tl"></span><span class="corner br"></span>
            <h4>// operator_log</h4>
            <ul>
              <li>full-stack software engineering</li>
              <li>AI workflow &amp; voice AI systems</li>
              <li>consulting &amp; commercial strategy background</li>
              <li>IoT &amp; operational systems experience</li>
              <li>comfortable with early-stage ambiguity</li>
              <li>available for international contracting</li>
            </ul>
          </div>
        </div>
        <div class="ascii-div" aria-hidden="true">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <div class="prompt">&gt; ./contact</div>
          <h2 class="h">Start a conversation</h2>
          <p class="sub">If you're building something in AI, voice, blockchain, fintech, insurance, or workflow automation — send me a note.</p>
        </div>

        <div class="contact-grid">
