---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

const sorted = all.sort((a, b) => {
  const ad = a.data.posted?.getTime() ?? 0;
  const bd = b.data.posted?.getTime() ?? 0;
  if (ad !== bd) return bd - ad;
  return a.data.title.localeCompare(b.data.title);
});

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return 'unpublished';
}

function wordCount(p: Post) {
  // Strip frontmatter-passthrough markers, code fences, and HTML tags before
  // counting words so the meta line reflects readable prose only.
  const raw = (p.body || '')
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]*`/g, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/[#>*_\-\[\]\(\)!|]/g, ' ');
  const words = raw.trim().split(/\s+/).filter(Boolean);
  return words.length;
}

function fmtWords(n: number) {
  if (n < 1000) return `${n} words`;
  return `${(n / 1000).toFixed(1)}k words`;
}

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const defaultOg = {
  src: '/og/default.png',
  alt: 'jonathan_abraham.os — shipping production AI for over 2 years',
};

function imageFor(p: Post) {
  const img = p.data.image ?? defaultOg;
  return {
    '@type': 'ImageObject',
    url: new URL(img.src, siteOrigin + '/').toString(),
    caption: img.alt,
  };
}

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteOrigin}/#blog`,
  url: siteOrigin + '/',
  name: 'Jonathan Abraham — posts',
  description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${siteOrigin}/posts/${p.slug}#post`,
    url: `${siteOrigin}/posts/${p.slug}`,
    headline: p.data.title,
    description: p.data.summary,
    image: imageFor(p),
    datePublished: p.data.posted?.toISOString(),
    keywords: p.data.tags.join(', '),
    author: { '@id': personId },
    ...(p.data.draft ? { creativeWorkStatus: 'Draft' } : {}),
  })),
};

const description = "Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Founder, Brokerloop.";
---
<Base
  title="Jonathan Abraham — building production-grade AI systems"
  description={description}
  jsonLd={blogJsonLd}
>
  <main id="content" class="wrap">
    <header class="page-head">
      <h1 class="prompt">&gt; ./posts</h1>
    </header>

    <ul class="post-list">
      {sorted.map((post) => {
        const wc = wordCount(post);
        return (
          <li>
            <a class="post-row" href={`/posts/${post.slug}`}>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
              <div class="meta">
                {post.data.draft && <><span class="draft">draft</span><span class="sep">·</span></>}
                <span>{fmt(post)}</span>
                <span class="sep">·</span><span>{fmtWords(wc)}</span>
                {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
                {post.data.tags.length > 0 && <><span class="sep">·</span><span class="tag">{post.data.tags.join(' · ')}</span></>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </main>
</Base>
