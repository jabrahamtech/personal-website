---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { computeReadTime } from '../lib/readTime';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

const sorted = all.sort((a, b) => {
  const ap = a.data.priority ?? Number.POSITIVE_INFINITY;
  const bp = b.data.priority ?? Number.POSITIVE_INFINITY;
  if (ap !== bp) return ap - bp;
  const ad = a.data.posted?.getTime() ?? 0;
  const bd = b.data.posted?.getTime() ?? 0;
  if (ad !== bd) return bd - ad;
  return a.data.title.localeCompare(b.data.title);
});

const contentTypeOrder = [
  'Learning Journey Guide',
  'Technical Build Breakdown',
  'Business Outcome Case Study',
  'Decision / Comparison Guide',
  'Diagnostic / Failure Mode Guide',
  'Playbook / Checklist / SOP Guide',
  'POV / Strategic Opinion Post',
] as const;

const contentTypeFilters = contentTypeOrder
  .map((value) => ({
    kind: 'type',
    value,
    count: sorted.filter((p) => p.data.contentTypes.includes(value)).length,
  }))
  .filter((f) => f.count > 0);

const clusterFilters = Array.from(new Set(sorted.map((p) => p.data.cluster).filter(Boolean)))
  .map((value) => ({
    kind: 'cluster',
    value: value as string,
    count: sorted.filter((p) => p.data.cluster === value).length,
  }));

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return 'unpublished';
}

function wordCount(p: Post) {
  // Strip frontmatter-passthrough markers, code fences, and HTML tags before
  // counting words so the meta line reflects readable prose only.
  const raw = (p.body || '')
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]*`/g, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/[#>*_\-\[\]\(\)!|]/g, ' ');
  const words = raw.trim().split(/\s+/).filter(Boolean);
  return words.length;
}

function fmtWords(n: number) {
  if (n < 1000) return `${n} words`;
  return `${(n / 1000).toFixed(1)}k words`;
}

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const defaultOg = {
  src: '/og/default.png',
  alt: 'jonathan_abraham.os — shipping production AI for over 2 years',
};

function imageFor(p: Post) {
  const img = p.data.image ?? defaultOg;
  return {
    '@type': 'ImageObject',
    url: new URL(img.src, siteOrigin + '/').toString(),
    caption: img.alt,
  };
}

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteOrigin}/#blog`,
  url: siteOrigin + '/',
  name: 'Jonathan Abraham — posts',
  description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${siteOrigin}/posts/${p.slug}#post`,
    url: `${siteOrigin}/posts/${p.slug}`,
    headline: p.data.title,
    description: p.data.summary,
    image: imageFor(p),
    datePublished: p.data.posted?.toISOString(),
    keywords: [...p.data.tags, ...p.data.contentTypes, p.data.cluster].filter(Boolean).join(', '),
    author: { '@id': personId },
    ...(p.data.draft ? { creativeWorkStatus: 'Draft' } : {}),
  })),
};

const description = "Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Founder, Brokerloop.";
---
<Base
  title="Jonathan Abraham — building production-grade AI systems"
  description={description}
  jsonLd={blogJsonLd}
>
  <main id="content" class="wrap">
    <header class="page-head">
      <h1 class="prompt"><span class="ph-prefix eng-only">./</span>posts</h1>
    </header>

    {(() => {
      const total = sorted.length;
      return (
        <div class="post-filters" id="post-filters" aria-label="filter upcoming drafts">
          <label class="filter-field" for="filter-type">
            <span class="filter-label">type</span>
            <select class="filter-select" id="filter-type" data-filter-kind="type">
              <option value="all">all content types ({total})</option>
              {contentTypeFilters.map((filter) => (
                <option value={filter.value}>{filter.value} ({filter.count})</option>
              ))}
            </select>
          </label>
          {clusterFilters.length > 1 && (
            <label class="filter-field" for="filter-cluster">
              <span class="filter-label">cluster</span>
              <select class="filter-select" id="filter-cluster" data-filter-kind="cluster">
                <option value="all">all clusters ({total})</option>
                {clusterFilters.map((filter) => (
                  <option value={filter.value}>{filter.value} ({filter.count})</option>
                ))}
              </select>
            </label>
          )}
          <span class="filter-hint">filter by release angle</span>
        </div>
      );
    })()}

    <ul class="post-list" id="post-list">
      {sorted.map((post) => {
        const wc = wordCount(post);
        const rt = post.data.readTime ?? computeReadTime(post.body || '');
        return (
          <li
            data-types={post.data.contentTypes.join('|')}
            data-cluster={post.data.cluster ?? ''}
            data-priority={post.data.priority ?? ''}
          >
            <a class="post-row" href={`/posts/${post.slug}`}>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
              <div class="meta">
                {post.data.draft && <><span class="draft">draft</span><span class="sep">·</span></>}
                {post.data.pipelineStatus && <><span>{post.data.pipelineStatus}</span><span class="sep">·</span></>}
                {post.data.priority && <><span>P{post.data.priority}</span><span class="sep">·</span></>}
                <span>{fmt(post)}</span>
                <span class="sep">·</span><span>{fmtWords(wc)}</span>
                <span class="sep">·</span><span>{rt}</span>
                {post.data.cluster && <><span class="sep">·</span><span class="tag tag-cluster">{post.data.cluster}</span></>}
                {post.data.contentTypes.length > 0 && <><span class="sep">·</span><span class="tag tag-cat">{post.data.contentTypes.join(' · ')}</span></>}
                {post.data.tags.length > 0 && <><span class="sep">·</span><span class="tag">{post.data.tags.join(' · ')}</span></>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <p class="post-empty" id="post-empty" hidden>nothing here in this filter — try another.</p>
  </main>

  <script is:inline>
    (function () {
      const root = document.getElementById('post-filters');
      const list = document.getElementById('post-list');
      const empty = document.getElementById('post-empty');
      if (!root || !list) return;
      const items = Array.from(list.querySelectorAll('li'));
      const selects = Array.from(root.querySelectorAll('.filter-select'));
      const storageKey = 'ja_post_filter_v2';

      function apply(kind, value) {
        let shown = 0;
        items.forEach((li) => {
          const types = (li.getAttribute('data-types') || '').split('|').filter(Boolean);
          const cluster = li.getAttribute('data-cluster') || '';
          const match = kind === 'all'
            || (kind === 'type' && types.indexOf(value) !== -1)
            || (kind === 'cluster' && cluster === value);
          li.hidden = !match;
          if (match) shown++;
        });
        selects.forEach((select) => {
          const selectKind = select.getAttribute('data-filter-kind') || '';
          select.value = selectKind === kind ? value : 'all';
        });
        if (empty) empty.hidden = shown !== 0;
        try { localStorage.setItem(storageKey, JSON.stringify({ kind, value })); } catch (_) {}
      }

      let initial = { kind: 'all', value: 'all' };
      try {
        const saved = JSON.parse(localStorage.getItem(storageKey) || 'null');
        if (
          saved
          && typeof saved.kind === 'string'
          && typeof saved.value === 'string'
          && (
            saved.kind === 'all'
            || selects.some((select) => select.getAttribute('data-filter-kind') === saved.kind && Array.from(select.options).some((option) => option.value === saved.value))
          )
        ) {
          initial = saved;
        }
      } catch (_) {}
      apply(initial.kind, initial.value);

      selects.forEach((select) => {
        select.addEventListener('change', () => {
          const value = select.value || 'all';
          apply(value === 'all' ? 'all' : select.getAttribute('data-filter-kind') || 'all', value);
        });
      });
    })();
  </script>
</Base>
