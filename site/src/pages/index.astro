---
import Base from '../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'posts'>;

const all = await getCollection('posts');

function comparePosts(a: Post, b: Post, order: 'asc' | 'desc' = 'desc') {
  const ad = a.data.posted?.getTime();
  const bd = b.data.posted?.getTime();
  if (ad !== undefined || bd !== undefined) {
    if (ad === undefined) return 1;
    if (bd === undefined) return -1;
    if (ad !== bd) return order === 'desc' ? bd - ad : ad - bd;
  }

  return order === 'desc'
    ? a.data.title.localeCompare(b.data.title)
    : b.data.title.localeCompare(a.data.title);
}

const sorted = [...all].sort((a, b) => comparePosts(a, b));

const contentTypeOrder = [
  'Learning Journey Guide',
  'Technical Build Breakdown',
  'Business Outcome Case Study',
  'Decision / Comparison Guide',
  'Diagnostic / Failure Mode Guide',
  'Playbook / Checklist / SOP Guide',
  'POV / Strategic Opinion Post',
] as const;

type ContentType = typeof contentTypeOrder[number];

const contentTypeLabels: Record<ContentType, string> = {
  'Learning Journey Guide': 'Guide',
  'Technical Build Breakdown': 'Build',
  'Business Outcome Case Study': 'Case study',
  'Decision / Comparison Guide': 'Decision',
  'Diagnostic / Failure Mode Guide': 'Diagnostic',
  'Playbook / Checklist / SOP Guide': 'Checklist',
  'POV / Strategic Opinion Post': 'Opinion',
};

const contentTypeFilters = contentTypeOrder
  .map((value) => ({
    kind: 'type',
    value,
    label: contentTypeLabels[value],
    count: sorted.filter((p) => p.data.contentTypes.includes(value)).length,
  }))
  .filter((f) => f.count > 0);

const clusterFilters = Array.from(new Set(sorted.map((p) => p.data.cluster).filter(Boolean)))
  .map((value) => ({
    kind: 'cluster',
    value: value as string,
    count: sorted.filter((p) => p.data.cluster === value).length,
  }));

function fmt(p: Post) {
  if (p.data.posted) return p.data.posted.toISOString().slice(0, 10);
  return '';
}

function contentTypeLabel(value: string) {
  return contentTypeLabels[value as ContentType] ?? value;
}

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;

const defaultOg = {
  src: '/og/default.png',
  alt: 'jonathan_abraham.os — shipping production AI for over 2 years',
};

function imageFor(p: Post) {
  const img = p.data.image ?? defaultOg;
  return {
    '@type': 'ImageObject',
    url: new URL(img.src, siteOrigin + '/').toString(),
    caption: img.alt,
  };
}

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteOrigin}/#blog`,
  url: siteOrigin + '/',
  name: 'Jonathan Abraham — posts',
  description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
  inLanguage: 'en',
  isPartOf: { '@id': siteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  blogPost: sorted.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${siteOrigin}/posts/${p.id}#post`,
    url: `${siteOrigin}/posts/${p.id}`,
    headline: p.data.title,
    description: p.data.summary,
    image: imageFor(p),
    datePublished: p.data.posted?.toISOString(),
    keywords: [...p.data.tags, ...p.data.contentTypes, p.data.cluster].filter(Boolean).join(', '),
    author: { '@id': personId },
    ...(p.data.draft ? { creativeWorkStatus: 'Draft' } : {}),
  })),
};

const description = "Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Technical founder, Brokerloop.";
---
<Base
  title="Jonathan Abraham — building production-grade AI systems"
  description={description}
  jsonLd={blogJsonLd}
>
  <main id="content" class="wrap">
    <header class="page-head">
      <h1 class="prompt"><span class="ph-prefix eng-only">./</span>posts</h1>
    </header>

    {(() => {
      const total = sorted.length;
      return (
        <div class="post-filters" id="post-filters" aria-label="filter upcoming drafts">
          <label class="filter-field" for="filter-type">
            <span class="filter-label">type</span>
            <select class="filter-select" id="filter-type" data-filter-kind="type">
              <option value="all">all types ({total})</option>
              {contentTypeFilters.map((filter) => (
                <option value={filter.value}>{filter.label} ({filter.count})</option>
              ))}
            </select>
          </label>
          {clusterFilters.length > 1 && (
            <label class="filter-field" for="filter-cluster">
              <span class="filter-label">cluster</span>
              <select class="filter-select" id="filter-cluster" data-filter-kind="cluster">
                <option value="all">all clusters ({total})</option>
                {clusterFilters.map((filter) => (
                  <option value={filter.value}>{filter.value} ({filter.count})</option>
                ))}
              </select>
            </label>
          )}
          <label class="filter-field filter-field-order" for="filter-order">
            <span class="filter-label">sort</span>
            <select class="filter-select" id="filter-order" data-order-control>
              <option value="desc" selected>newest first</option>
              <option value="asc">oldest first</option>
            </select>
          </label>
        </div>
      );
    })()}

    <p class="post-status" id="post-status" hidden aria-live="polite"></p>

    <ul class="post-list" id="post-list">
      {sorted.map((post) => {
        const posted = fmt(post);
        return (
          <li
            data-types={post.data.contentTypes.join('|')}
            data-cluster={post.data.cluster ?? ''}
            data-posted-time={post.data.posted?.getTime() ?? ''}
            data-title={post.data.title}
          >
            <a class="post-row" href={`/posts/${post.id}`}>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
              <div class="meta">
                {post.data.draft && <span class="draft">draft</span>}
                {posted && <span>{posted}</span>}
                {post.data.cluster && <span class="tag tag-cluster">{post.data.cluster}</span>}
                {post.data.contentTypes.map((type) => (
                  <span class="tag tag-cat" title={type}>{contentTypeLabel(type)}</span>
                ))}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <p class="post-empty" id="post-empty" hidden>nothing here in this filter — try another.</p>
  </main>

  <script is:inline>
    (function () {
      const root = document.getElementById('post-filters');
      const list = document.getElementById('post-list');
      const empty = document.getElementById('post-empty');
      const status = document.getElementById('post-status');
      if (!root || !list) return;
      const items = Array.from(list.querySelectorAll('li'));
      const filterSelects = Array.from(root.querySelectorAll('.filter-select[data-filter-kind]'));
      const orderSelect = root.querySelector('[data-order-control]');
      const storageKey = 'ja_post_filter_v3';
      const total = items.length;

      function sortItems(order) {
        const normalised = order === 'asc' ? 'asc' : 'desc';
        items.sort((a, b) => {
          const aRawDate = a.getAttribute('data-posted-time') || '';
          const bRawDate = b.getAttribute('data-posted-time') || '';
          const aHasDate = aRawDate !== '';
          const bHasDate = bRawDate !== '';
          if (aHasDate || bHasDate) {
            if (!aHasDate) return 1;
            if (!bHasDate) return -1;
            const diff = Number(aRawDate) - Number(bRawDate);
            if (diff !== 0) return normalised === 'desc' ? -diff : diff;
          }

          const at = a.getAttribute('data-title') || '';
          const bt = b.getAttribute('data-title') || '';
          return normalised === 'desc' ? at.localeCompare(bt) : bt.localeCompare(at);
        });
        items.forEach((li) => list.appendChild(li));
      }

      function describeFilter(kind, value) {
        if (kind === 'all' || value === 'all') return null;
        // Pull the human label off the option so the status reads the same
        // way the user picked it — "Showing 2 of 7 · Guide" rather than
        // the raw schema value "Learning Journey Guide".
        const select = filterSelects.find((s) => s.getAttribute('data-filter-kind') === kind);
        if (!select) return value;
        const option = Array.from(select.options).find((o) => o.value === value);
        if (!option) return value;
        // Option labels embed the count (e.g. "Guide (2)") — strip it.
        return option.textContent.replace(/\s*\(\d+\)\s*$/, '').trim();
      }

      function apply(kind, value, order) {
        const normalisedOrder = order === 'asc' ? 'asc' : 'desc';
        sortItems(normalisedOrder);
        let shown = 0;
        items.forEach((li) => {
          const types = (li.getAttribute('data-types') || '').split('|').filter(Boolean);
          const cluster = li.getAttribute('data-cluster') || '';
          const match = kind === 'all'
            || (kind === 'type' && types.indexOf(value) !== -1)
            || (kind === 'cluster' && cluster === value);
          li.hidden = !match;
          if (match) shown++;
        });
        filterSelects.forEach((select) => {
          const selectKind = select.getAttribute('data-filter-kind') || '';
          select.value = selectKind === kind ? value : 'all';
        });
        if (orderSelect) orderSelect.value = normalisedOrder;
        if (empty) empty.hidden = shown !== 0;
        if (status) {
          // Visible count makes the type/cluster mutual-exclusion obvious:
          // if a user picks one filter while another was active, they see
          // the count change AND the second select snap to "all".
          const label = describeFilter(kind, value);
          if (label) {
            status.hidden = false;
            status.textContent = 'Showing ' + shown + ' of ' + total + ' · ' + label;
          } else {
            status.hidden = true;
            status.textContent = '';
          }
        }
        try { localStorage.setItem(storageKey, JSON.stringify({ kind, value, order: normalisedOrder })); } catch (_) {}
      }

      let initial = { kind: 'all', value: 'all', order: 'desc' };
      try {
        const saved = JSON.parse(localStorage.getItem(storageKey) || 'null');
        // Validation has to check `value` even when `kind === 'all'`, or
        // a stale value (e.g. a cluster name that no longer exists in
        // the content collection) would pass through unchecked.
        const validAllShape = saved && saved.kind === 'all' && saved.value === 'all';
        const validFilterShape = saved
          && typeof saved.kind === 'string'
          && typeof saved.value === 'string'
          && filterSelects.some((select) =>
            select.getAttribute('data-filter-kind') === saved.kind
            && Array.from(select.options).some((option) => option.value === saved.value)
          );
        if (validAllShape || validFilterShape) {
          initial = {
            kind: saved.kind,
            value: saved.value,
            order: saved.order === 'asc' ? 'asc' : 'desc',
          };
        }
      } catch (_) {}
      apply(initial.kind, initial.value, initial.order);

      filterSelects.forEach((select) => {
        select.addEventListener('change', () => {
          const value = select.value || 'all';
          const order = orderSelect ? orderSelect.value : 'desc';
          apply(value === 'all' ? 'all' : select.getAttribute('data-filter-kind') || 'all', value, order);
        });
      });
      if (orderSelect) {
        orderSelect.addEventListener('change', () => {
          const selectedFilter = filterSelects.find((select) => select.value !== 'all');
          const kind = selectedFilter ? selectedFilter.getAttribute('data-filter-kind') || 'all' : 'all';
          const value = selectedFilter ? selectedFilter.value || 'all' : 'all';
          apply(kind, value, orderSelect.value);
        });
      }
    })();
  </script>
</Base>
