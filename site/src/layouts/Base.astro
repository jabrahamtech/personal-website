---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import StatusStrip from '../components/StatusStrip.astro';
import Footer from '../components/Footer.astro';
import BootSequence from '../components/BootSequence.astro';

type PageType = 'website' | 'article' | 'profile';

interface Props {
  title?: string;
  description?: string;
  /** Full URL or absolute path (will be made absolute against site). PNG/JPG preferred for OG. */
  image?: string;
  imageAlt?: string;
  /** Intrinsic pixel dimensions of the OG image. Defaults to 1200x630 (the standard OG card size). */
  imageWidth?: number;
  imageHeight?: number;
  /** OG type. Posts use "article". */
  pageType?: PageType;
  /** Article meta — only used when pageType === 'article'. */
  publishedAt?: Date;
  modifiedAt?: Date;
  tags?: string[];
  /** Optional pre-built JSON-LD object(s) to inject into <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** If true, advise crawlers not to index this page. */
  noindex?: boolean;
}

const {
  title = 'Jonathan Abraham — building production-grade AI systems',
  description = 'Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Founder, Brokerloop.',
  image = '/og/default.png',
  imageAlt = 'jonathan_abraham.os — building production-grade systems for over 5 years',
  imageWidth = 1200,
  imageHeight = 630,
  pageType = 'website',
  publishedAt,
  modifiedAt,
  tags = [],
  jsonLd,
  noindex = false,
} = Astro.props;

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, siteOrigin + '/').toString();
const ogImage = new URL(image, siteOrigin + '/').toString();

/* Site-wide identity (Person + WebSite) — emitted on every page so AEO/LLM
   crawlers always have an anchor entity to attach Article schemas to. */
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;
const siteWideJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    name: 'Jonathan Abraham',
    givenName: 'Jonathan',
    familyName: 'Abraham',
    alternateName: ['Jono Abraham', 'jabrahamtech'],
    url: siteOrigin + '/',
    image: new URL('/about/avatar.jpeg', siteOrigin + '/').toString(),
    jobTitle: 'AI engineer',
    description: 'About 5 years building production systems, the last 2 on AI. Voice agents, intake automation, and the backend they sit on. Founder of Brokerloop. Open to select work in Australia and the US.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Melbourne',
      addressRegion: 'VIC',
      addressCountry: 'AU',
    },
    homeLocation: {
      '@type': 'Place',
      name: 'Melbourne, Australia',
    },
    worksFor: {
      '@type': 'Organization',
      name: 'Brokerloop',
      description: 'Australian insurtech building automation infrastructure for insurance brokers.',
    },
    knowsAbout: [
      // Capabilities — business-recognisable
      'Production AI systems',
      'Enterprise AI deployment',
      'AI consulting',
      'AI engineering',
      'AI advisory',
      'Voice AI',
      'Conversational AI',
      'Intake automation',
      'Workflow automation',
      'IoT automation',
      'Industrial automation',
      'Greenfield system design',
      '0-to-1 product engineering',
      'Insurtech',
      'Insurance technology',
      'Regulated industries',
      // Technical surfaces — engineering-recognisable
      'Voice agents',
      'AI agents',
      'Agentic workflows',
      'LLM application engineering',
      'Retrieval augmented generation',
      'Function calling',
      'LLM evaluation',
      'Speech recognition',
      'Text to speech',
      'Real-time voice systems',
      'Backend infrastructure',
      'Event-driven systems',
      'Distributed systems',
      'Onchain engineering',
      'Solidity smart contracts',
      'EVM (Base) development',
      'Go programming',
      'TypeScript',
      'React',
      'Postgres',
      'AWS',
      'LangGraph',
      'Model Context Protocol (MCP)',
    ],
    sameAs: [
      'https://github.com/jabrahamtech',
      'https://www.linkedin.com/in/jabrahamtech',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': siteId,
    url: siteOrigin + '/',
    name: 'Jonathan Abraham',
    alternateName: 'jonathan_abraham.os',
    description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
    inLanguage: 'en',
    publisher: { '@id': personId },
    author: { '@id': personId },
  },
];

const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...siteWideJsonLd, ...extraJsonLd];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0b0e0c" />
  <meta name="author" content="Jonathan Abraham" />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={pageType} />
  <meta property="og:site_name" content="Jonathan Abraham" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content={String(imageWidth)} />
  <meta property="og:image:height" content={String(imageHeight)} />
  <meta property="og:image:alt" content={imageAlt} />
  {pageType === 'article' && publishedAt && (
    <meta property="article:published_time" content={publishedAt.toISOString()} />
  )}
  {pageType === 'article' && modifiedAt && (
    <meta property="article:modified_time" content={modifiedAt.toISOString()} />
  )}
  {pageType === 'article' && (
    <meta property="article:author" content="Jonathan Abraham" />
  )}
  {pageType === 'article' && tags.map((t) => (
    <meta property="article:tag" content={t} />
  ))}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <!-- Favicon set: SVG for modern browsers, PNG for Google's search-result
       crawler (which doesn't reliably handle data: URIs), Apple touch icon
       for iOS home screen. The SVG href is rewritten by the mode resolver
       below so paper/eng each get a tonally-matched mark. -->
  <link id="favicon-svg" rel="icon" type="image/svg+xml" href="/favicon-paper.svg" />
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Jonathan Abraham — posts" href="/rss.xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {allJsonLd.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)}></script>
  ))}

  <!-- Pre-paint mode resolver: paper is default; /terminal forces eng,
       #eng URL hash forces eng, otherwise localStorage decides. Sets
       data-mode on <html> synchronously in <head>. -->
  <script is:inline>
    (function () {
      try {
        var stored = localStorage.getItem('ja_mode');
        var path = (location.pathname.replace(/\/$/, '') || '/');
        var hash = location.hash || '';
        var mode = 'paper';
        if (path === '/terminal') mode = 'eng';
        else if (hash === '#eng') { mode = 'eng'; localStorage.setItem('ja_mode', 'eng'); }
        else if (stored === 'eng' || stored === 'paper') mode = stored;
        document.documentElement.dataset.mode = mode;
        var icon = document.getElementById('favicon-svg');
        if (icon) icon.href = mode === 'eng' ? '/favicon.svg' : '/favicon-paper.svg';
      } catch (_) {}
    })();
  </script>
</head>
<body class="mode-paper">
  <!-- Synchronous mode swap. Body is server-rendered with mode-paper so the
       default visitor never sees a flash; this script runs before any
       visible child paints, so eng-mode users also avoid the flash. -->
  <script is:inline>
    (function () {
      try {
        var mode = document.documentElement.dataset.mode;
        if (mode === 'eng') {
          document.body.classList.remove('mode-paper');
          document.body.classList.add('mode-eng');
        }
      } catch (_) {}
    })();
  </script>
  <a class="skip-link" href="#content">skip to content</a>
  <BootSequence />
  <Nav />
  <StatusStrip />
  <slot />
  <Footer />

  <!-- Engineer-only page loader. Paper mode skips the click intercept
       entirely (see Base.astro inline script below). -->
  <div id="page-loader" class="page-loader eng-only" hidden aria-hidden="true">
    <div class="pl-term">
      <div class="pl-term-bar">
        <span class="pl-light r"></span>
        <span class="pl-light y"></span>
        <span class="pl-light g"></span>
        <span class="pl-term-title">system.loader</span>
      </div>
      <div class="pl-term-body">
        <span class="pl-line"><span class="pl-arrow">▸</span> initialising request <span class="pl-ok">[OK]</span></span>
        <span class="pl-line"><span class="pl-arrow">▸</span> resolving route <span class="pl-ok">[OK]</span></span>
        <span class="pl-line"><span class="pl-arrow">▸</span> mounting page<span class="pl-cursor"></span></span>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const loader = document.getElementById('page-loader');
      if (!loader) return;
      function isInternalNavLink(a) {
        if (!a || a.tagName !== 'A') return false;
        const href = a.getAttribute('href');
        if (!href) return false;
        if (a.target === '_blank' || a.hasAttribute('download')) return false;
        if (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')) return false;
        if (a.dataset.noLoader === 'true') return false;
        try {
          const url = new URL(href, location.href);
          if (url.origin !== location.origin) return false;
          if (url.pathname === location.pathname && url.hash) return false;
          return true;
        } catch (_) { return false; }
      }
      function show() {
        loader.hidden = false;
        loader.setAttribute('aria-hidden', 'false');
        // Force a reflow so the entrance animation always plays from frame 0.
        void loader.offsetWidth;
        loader.classList.add('on');
      }
      function hide() {
        loader.classList.remove('on');
        loader.hidden = true;
        loader.setAttribute('aria-hidden', 'true');
      }
      document.addEventListener('click', (e) => {
        if (e.defaultPrevented) return;
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const a = e.target && e.target.closest && e.target.closest('a');
        if (!isInternalNavLink(a)) return;
        // Paper mode skips the loader entirely — the terminal-frame overlay
        // reads as a flash to non-technical readers. Native navigation only.
        if (document.body.classList.contains('mode-paper')) return;
        // Let the animation breathe before navigation. 380ms is long enough for
        // the rings + figure to feel deliberate, short enough to stay snappy.
        e.preventDefault();
        show();
        const href = a.href;
        setTimeout(() => { window.location.href = href; }, 380);
      });
      // bfcache restore (back/forward) — page DOM is reused, so the loader
      // would otherwise stay visible on return.
      window.addEventListener('pageshow', (e) => { if (e.persisted) hide(); });
    })();
  </script>
</body>
</html>
