---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import StatusStrip from '../components/StatusStrip.astro';
import Footer from '../components/Footer.astro';
import BootSequence from '../components/BootSequence.astro';

type PageType = 'website' | 'article' | 'profile';

interface Props {
  title?: string;
  description?: string;
  /** Full URL or absolute path (will be made absolute against site). PNG/JPG preferred for OG. */
  image?: string;
  imageAlt?: string;
  /** OG type. Posts use "article". */
  pageType?: PageType;
  /** Article meta — only used when pageType === 'article'. */
  publishedAt?: Date;
  modifiedAt?: Date;
  tags?: string[];
  /** Optional pre-built JSON-LD object(s) to inject into <head>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** If true, advise crawlers not to index this page. */
  noindex?: boolean;
}

const {
  title = 'Jonathan Abraham — building production-grade AI systems',
  description = 'Notes from Jonathan Abraham on shipping AI that actually has to work. Voice agents, backend systems, and what it takes to run an insurtech. Founder, Brokerloop.',
  image = '/og/default.png',
  imageAlt = 'jonathan_abraham.os — building production-grade systems for over 5 years',
  pageType = 'website',
  publishedAt,
  modifiedAt,
  tags = [],
  jsonLd,
  noindex = false,
} = Astro.props;

const siteOrigin = (Astro.site ?? new URL('https://jabrahamtech.com')).toString().replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, siteOrigin + '/').toString();
const ogImage = new URL(image, siteOrigin + '/').toString();

/* Site-wide identity (Person + WebSite) — emitted on every page so AEO/LLM
   crawlers always have an anchor entity to attach Article schemas to. */
const personId = `${siteOrigin}/#jonathan`;
const siteId = `${siteOrigin}/#site`;
const siteWideJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    name: 'Jonathan Abraham',
    givenName: 'Jonathan',
    familyName: 'Abraham',
    alternateName: ['Jono Abraham', 'jabrahamtech'],
    url: siteOrigin + '/',
    image: new URL('/about/avatar.jpeg', siteOrigin + '/').toString(),
    jobTitle: 'AI engineer',
    description: 'About 5 years building production systems, the last 2 on AI. Voice agents, intake automation, and the backend they sit on. Founder of Brokerloop. Open to select work in Australia and the US.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Melbourne',
      addressRegion: 'VIC',
      addressCountry: 'AU',
    },
    homeLocation: {
      '@type': 'Place',
      name: 'Melbourne, Australia',
    },
    worksFor: {
      '@type': 'Organization',
      name: 'Brokerloop',
      description: 'Australian insurtech building automation infrastructure for insurance brokers.',
    },
    knowsAbout: [
      // Capabilities — business-recognisable
      'Production AI systems',
      'Enterprise AI deployment',
      'AI consulting',
      'AI engineering',
      'AI advisory',
      'Voice AI',
      'Conversational AI',
      'Intake automation',
      'Workflow automation',
      'IoT automation',
      'Industrial automation',
      'Greenfield system design',
      '0-to-1 product engineering',
      'Insurtech',
      'Insurance technology',
      'Regulated industries',
      // Technical surfaces — engineering-recognisable
      'Voice agents',
      'AI agents',
      'Agentic workflows',
      'LLM application engineering',
      'Retrieval augmented generation',
      'Function calling',
      'LLM evaluation',
      'Speech recognition',
      'Text to speech',
      'Real-time voice systems',
      'Backend infrastructure',
      'Event-driven systems',
      'Distributed systems',
      'Onchain engineering',
      'Solidity smart contracts',
      'EVM (Base) development',
      'Go programming',
      'TypeScript',
      'React',
      'Postgres',
      'AWS',
      'LangGraph',
      'Model Context Protocol (MCP)',
    ],
    sameAs: [
      'https://github.com/jabrahamtech',
      'https://www.linkedin.com/in/jabrahamtech',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': siteId,
    url: siteOrigin + '/',
    name: 'Jonathan Abraham',
    alternateName: 'jonathan_abraham.os',
    description: "Notes on shipping AI that has to actually work. Voice agents, intake automation, and the backend they run on.",
    inLanguage: 'en',
    publisher: { '@id': personId },
    author: { '@id': personId },
  },
];

const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...siteWideJsonLd, ...extraJsonLd];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0b0e0c" />
  <meta name="author" content="Jonathan Abraham" />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={pageType} />
  <meta property="og:site_name" content="Jonathan Abraham" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={imageAlt} />
  {pageType === 'article' && publishedAt && (
    <meta property="article:published_time" content={publishedAt.toISOString()} />
  )}
  {pageType === 'article' && modifiedAt && (
    <meta property="article:modified_time" content={modifiedAt.toISOString()} />
  )}
  {pageType === 'article' && (
    <meta property="article:author" content="Jonathan Abraham" />
  )}
  {pageType === 'article' && tags.map((t) => (
    <meta property="article:tag" content={t} />
  ))}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <link rel="icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><rect width='16' height='16' fill='%230b0e0c'/><g fill='%237dff8a'><rect x='3' y='3' width='2' height='2'/><rect x='7' y='3' width='2' height='2'/><rect x='11' y='3' width='2' height='2'/><rect x='3' y='7' width='10' height='2'/><rect x='3' y='11' width='2' height='2'/><rect x='11' y='11' width='2' height='2'/></g></svg>" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Jonathan Abraham — posts" href="/rss.xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {allJsonLd.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)}></script>
  ))}
</head>
<body>
  <a class="skip-link" href="#content">skip to content</a>
  <BootSequence />
  <Nav />
  <StatusStrip />
  <slot />
  <Footer />

  <div id="page-loader" class="page-loader" hidden aria-hidden="true">
    <div class="pl-stage">
      <div class="pl-bob">
        <div>
          <svg viewBox="0 0 200 240" class="pl-svg" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="pl-hair" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fff5b8"/>
                <stop offset="55%" stop-color="#ffd84d"/>
                <stop offset="100%" stop-color="#d49920"/>
              </linearGradient>
              <linearGradient id="pl-skin" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#a8744f"/>
                <stop offset="100%" stop-color="#7a4f30"/>
              </linearGradient>
              <linearGradient id="pl-jacket" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#23262c"/>
                <stop offset="100%" stop-color="#0a0c0e"/>
              </linearGradient>
            </defs>

            <!-- center origin near sternum -->
            <g transform="translate(100 120)">
              <!-- standing upright, just gently floating -->
              <g>

                <!-- LEGS — chibi proportions, slightly bent, toes pointed down (hovering tell) -->
                <!-- left leg (back) -->
                <path d="M -10 26 Q -12 46 -10 64 Q -6 70 0 70 Q 2 56 0 26 Z" fill="#15181a"/>
                <ellipse cx="-3" cy="72" rx="7" ry="3.5" fill="#0a0c0e"/>
                <!-- right leg (front) -->
                <path d="M 0 26 Q 4 46 6 64 Q 12 70 18 66 Q 14 50 10 26 Z" fill="url(#pl-jacket)"/>
                <ellipse cx="13" cy="68" rx="7" ry="3.5" fill="#0a0c0e"/>

                <!-- TORSO (blazer + shirt) -->
                <!-- jacket body -->
                <path d="M -18 -8 Q -8 -14 0 -14 Q 9 -14 18 -8 L 20 26 Q 9 30 0 30 Q -10 30 -20 26 Z" fill="url(#pl-jacket)"/>
                <!-- left lapel shadow -->
                <path d="M -18 -8 L -10 -4 L -8 26 L -20 26 Z" fill="#0a0c0e"/>
                <!-- right lapel shadow -->
                <path d="M 18 -8 L 10 -4 L 8 26 L 20 26 Z" fill="#0a0c0e"/>
                <!-- inner v-neck shirt -->
                <path d="M -7 -8 L 0 2 L 7 -8 L 6 14 L -6 14 Z" fill="#06080a"/>

                <!-- ARMS — bent at elbows, fists clenched at hip-level (classic SSJ stance) -->
                <!-- left arm (upper) -->
                <path d="M -18 -4 Q -28 4 -28 16 Q -22 18 -18 14 Q -14 8 -12 0 Z" fill="#15181a"/>
                <!-- left forearm + fist -->
                <path d="M -28 14 Q -28 24 -22 28 Q -16 28 -14 22 L -16 14 Z" fill="url(#pl-jacket)"/>
                <circle cx="-19" cy="28" r="5" fill="url(#pl-skin)"/>
                <path d="M -22 27 L -16 27" stroke="#3a2014" stroke-width="0.7" stroke-linecap="round" opacity="0.5"/>

                <!-- right arm (upper) — mirror, slightly forward -->
                <path d="M 18 -4 Q 28 4 28 16 Q 22 18 18 14 Q 14 8 12 0 Z" fill="url(#pl-jacket)"/>
                <!-- right forearm + fist -->
                <path d="M 28 14 Q 28 24 22 28 Q 16 28 14 22 L 16 14 Z" fill="url(#pl-jacket)"/>
                <circle cx="19" cy="28" r="5" fill="url(#pl-skin)"/>
                <path d="M 16 27 L 22 27" stroke="#3a2014" stroke-width="0.7" stroke-linecap="round" opacity="0.5"/>

                <!-- NECK -->
                <rect x="-6" y="-20" width="12" height="10" fill="url(#pl-skin)"/>
                <ellipse cx="0" cy="-10" rx="7" ry="2.5" fill="#2a1408" opacity="0.4"/>

                <!-- HEAD -->
                <ellipse cx="14" cy="-30" rx="3" ry="5" fill="url(#pl-skin)"/>
                <ellipse cx="0" cy="-30" rx="16" ry="18" fill="url(#pl-skin)"/>
                <!-- jaw stubble -->
                <ellipse cx="0" cy="-20" rx="11" ry="4" fill="#2a1408" opacity="0.3"/>
                <!-- eyebrows: gentle arch (relaxed, friendly) -->
                <path d="M -11 -38 Q -7 -39 -3 -38" stroke="#1a0a04" stroke-width="2" stroke-linecap="round" fill="none"/>
                <path d="M 3 -38 Q 7 -39 11 -38" stroke="#1a0a04" stroke-width="2" stroke-linecap="round" fill="none"/>
                <!-- eyes: closed/smiling arcs (curve up like ^ ^) -->
                <path d="M -9 -31 Q -6 -33 -3 -31" stroke="#1a0a04" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                <path d="M 3 -31 Q 6 -33 9 -31" stroke="#1a0a04" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                <!-- mouth: warm smile curve -->
                <path d="M -5 -21 Q 0 -16 5 -21" stroke="#2a1208" stroke-width="1.6" stroke-linecap="round" fill="none"/>

                <!-- HAIR — only on top + front of head, no random side bolts -->
                <g class="pl-hair">
                  <!-- forehead-anchored fan of golden spikes pointing UP -->
                  <path d="
                    M -16 -42
                    L -22 -64 L -10 -52
                    L -16 -78 L -4 -56
                    L -8 -84 L 2 -58
                    L 0 -90 L 8 -60
                    L 6 -86 L 14 -58
                    L 12 -78 L 20 -54
                    L 22 -68 L 26 -52
                    L 26 -42
                    Z"
                    fill="url(#pl-hair)" stroke="#a87010" stroke-width="1.2" stroke-linejoin="round"/>
                  <!-- forehead shadow under hair -->
                  <path d="M -14 -42 L 14 -42 L 12 -38 L -12 -38 Z" fill="#a87010" opacity="0.6"/>
                </g>
              </g>
            </g>
          </svg>
        </div>
      </div>
      <div class="pl-shadow" aria-hidden="true"></div>
    </div>
    <div class="pl-label">one moment please<span class="pl-dots">...</span></div>
  </div>

  <script is:inline>
    (function () {
      const loader = document.getElementById('page-loader');
      if (!loader) return;
      function isInternalNavLink(a) {
        if (!a || a.tagName !== 'A') return false;
        const href = a.getAttribute('href');
        if (!href) return false;
        if (a.target === '_blank' || a.hasAttribute('download')) return false;
        if (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')) return false;
        if (a.dataset.noLoader === 'true') return false;
        try {
          const url = new URL(href, location.href);
          if (url.origin !== location.origin) return false;
          if (url.pathname === location.pathname && url.hash) return false;
          return true;
        } catch (_) { return false; }
      }
      function show() {
        loader.hidden = false;
        loader.setAttribute('aria-hidden', 'false');
        // Force a reflow so the entrance animation always plays from frame 0.
        void loader.offsetWidth;
        loader.classList.add('on');
      }
      function hide() {
        loader.classList.remove('on');
        loader.hidden = true;
        loader.setAttribute('aria-hidden', 'true');
      }
      document.addEventListener('click', (e) => {
        if (e.defaultPrevented) return;
        if (e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const a = e.target && e.target.closest && e.target.closest('a');
        if (!isInternalNavLink(a)) return;
        // Let the animation breathe before navigation. 380ms is long enough for
        // the rings + figure to feel deliberate, short enough to stay snappy.
        e.preventDefault();
        show();
        const href = a.href;
        setTimeout(() => { window.location.href = href; }, 380);
      });
      // bfcache restore (back/forward) — page DOM is reused, so the loader
      // would otherwise stay visible on return.
      window.addEventListener('pageshow', (e) => { if (e.persisted) hide(); });
    })();
  </script>
</body>
</html>
