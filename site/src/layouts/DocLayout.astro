---
import Base from './Base.astro';

interface Crumb { href?: string; label: string }

interface Props {
  title: string;
  description: string;
  promptPath: string;
  crumbs: Crumb[];
  metaRow?: { label: string; value: string }[];
  tags?: string[];
  /** OG image (post cover, if any). */
  image?: string;
  imageAlt?: string;
  /** Article meta — passed through to <Base>. */
  pageType?: 'article' | 'website' | 'profile';
  publishedAt?: Date;
  modifiedAt?: Date;
  /** Optional pre-built JSON-LD (BlogPosting/BreadcrumbList) for posts. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Optional hex post identifier (e.g. "0x03") rendered in meta + EOF. */
  postId?: string;
}

const {
  title,
  description,
  promptPath,
  crumbs,
  metaRow,
  tags,
  image,
  imageAlt,
  pageType = 'website',
  publishedAt,
  modifiedAt,
  jsonLd,
  postId,
} = Astro.props;
---
<Base
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  pageType={pageType}
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
  tags={tags}
  jsonLd={jsonLd}
>
  <main id="content" class="doc">
    <div class="wrap">
      <div class="post-prompt">&gt; {promptPath}</div>
      <h1>{title.replace(/ — Jonathan Abraham$/, '')}</h1>
      {metaRow && (
        <div class="meta-row">
          {metaRow.map((m) => <span><b>{m.label}</b> {m.value}</span>)}
        </div>
      )}
      {tags && tags.length > 0 && (
        <div style="margin:0 0 24px">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}

      <article class="prose">
        <slot />
        {postId && (
          <div class="post-eof" aria-hidden="true">[EOF — {postId}] <span class="ok">[exit 0]</span></div>
        )}
        <slot name="footer" />
      </article>
    </div>
  </main>
  <script is:inline>
    (function () {
      var COPY = '[copy]';
      var OK = '[ok]';
      var ERR = '[err]';
      document.querySelectorAll('article.prose pre').forEach(function (pre) {
        if (pre.querySelector('.copy-btn')) return;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = COPY;
        btn.setAttribute('aria-label', 'copy code to clipboard');
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          var code = pre.querySelector('code');
          var text = (code ? code.innerText : pre.innerText) || '';
          var done = function (label, ok) {
            btn.textContent = label;
            if (ok) btn.classList.add('ok'); else btn.classList.remove('ok');
            setTimeout(function () { btn.textContent = COPY; btn.classList.remove('ok'); }, 1200);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function () { done(OK, true); }, function () { done(ERR, false); });
          } else {
            done(ERR, false);
          }
        });
        pre.appendChild(btn);
      });
    })();
  </script>
</Base>
