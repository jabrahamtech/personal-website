---
import Base from './Base.astro';

interface Crumb { href?: string; label: string }

interface Props {
  title: string;
  description: string;
  promptPath: string;
  crumbs: Crumb[];
  metaRow?: { label: string; value: string }[];
  tags?: string[];
  /** OG image (post cover, if any). */
  image?: string;
  imageAlt?: string;
  /** Article meta — passed through to <Base>. */
  pageType?: 'article' | 'website' | 'profile';
  publishedAt?: Date;
  modifiedAt?: Date;
  /** Optional pre-built JSON-LD (BlogPosting/BreadcrumbList) for posts. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  promptPath,
  crumbs,
  metaRow,
  tags,
  image,
  imageAlt,
  pageType = 'website',
  publishedAt,
  modifiedAt,
  jsonLd,
} = Astro.props;
---
<Base
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  pageType={pageType}
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
  tags={tags}
  jsonLd={jsonLd}
>
  <main id="content" class="doc">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <>
            {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current={i === crumbs.length - 1 ? 'page' : undefined}>{c.label}</span>}
            {i < crumbs.length - 1 && <span class="sep">/</span>}
          </>
        ))}
      </nav>
      <div class="post-prompt">&gt; {promptPath}</div>
      <h1>{title.replace(/ — Jonathan Abraham$/, '')}</h1>
      {metaRow && (
        <div class="meta-row">
          {metaRow.map((m) => <span><b>{m.label}</b> {m.value}</span>)}
        </div>
      )}
      {tags && tags.length > 0 && (
        <div style="margin:0 0 24px">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}

      <article class="prose">
        <slot />
        <slot name="footer" />
      </article>
    </div>
  </main>
</Base>
