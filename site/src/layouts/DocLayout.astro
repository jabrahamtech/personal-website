---
import Base from './Base.astro';

interface Crumb { href?: string; label: string }
interface Heading { depth: number; slug: string; text: string }

interface Props {
  title: string;
  description: string;
  promptPath: string;
  crumbs: Crumb[];
  metaRow?: { label: string; value: string }[];
  tags?: string[];
  /** OG image (post cover, if any). */
  image?: string;
  imageAlt?: string;
  /** Article meta — passed through to <Base>. */
  pageType?: 'article' | 'website' | 'profile';
  publishedAt?: Date;
  modifiedAt?: Date;
  /** Optional pre-built JSON-LD (BlogPosting/BreadcrumbList) for posts. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Optional hex post identifier (e.g. "0x03") rendered in meta + EOF. */
  postId?: string;
  /** Headings extracted from MDX render() — used to build the right-rail TOC. */
  headings?: Heading[];
  /** GitHub edit URL for the source MDX file. */
  editUrl?: string;
  /** Repo-relative source path, shown in the edit link. */
  sourcePath?: string;
}

const {
  title,
  description,
  promptPath,
  crumbs,
  metaRow,
  tags,
  image,
  imageAlt,
  pageType = 'website',
  publishedAt,
  modifiedAt,
  jsonLd,
  postId,
  headings = [],
  editUrl,
  sourcePath,
} = Astro.props;

// Right-rail TOC: only H2/H3 (H1 is the page title; H4+ is too noisy).
// rehype-autolink-headings appends a "#" anchor inside each heading, which
// Astro's heading-text extraction concatenates. Strip it so the TOC reads
// clean ("Why Astro" not "Why Astro#").
const tocItems = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ ...h, text: h.text.replace(/\s*#\s*$/, '').trim() }));
const showToc = tocItems.length >= 2;
---
<Base
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  pageType={pageType}
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
  tags={tags}
  jsonLd={jsonLd}
>
  <div class="reading-progress" id="reading-progress" aria-hidden="true"><span></span></div>
  <main id="content" class={`doc${showToc ? ' has-toc' : ''}`}>
    <div class="wrap">
      {showToc && (
        <details class="toc toc-mobile" id="toc-mobile" aria-label="table of contents">
          <summary>
            <span class="toc-prompt eng-only">&gt; ./contents</span>
            <span class="toc-prompt paper-only">Contents</span>
            <span class="toc-count">{tocItems.length}</span>
            <span class="toc-caret" aria-hidden="true">▾</span>
          </summary>
          <ul>
            {tocItems.map((h) => (
              <li class={`d${h.depth}`}>
                <a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      )}
      <div class={`doc-grid${showToc ? '' : ' no-toc'}`}>
        <div class="doc-main">
          <div class="post-prompt eng-only">&gt; {promptPath}</div>
          <p class="page-kicker paper-only" aria-hidden="true">{promptPath.replace(/^\.?\//, '/')}</p>
          <h1>{title.replace(/ — Jonathan Abraham$/, '')}</h1>
          {metaRow && (
            <div class="meta-row">
              {metaRow.map((m) => <span><b>{m.label}</b> {m.value}</span>)}
            </div>
          )}
          {tags && tags.length > 0 && (
            <div style="margin:0 0 24px">
              {tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          )}
          <article class="prose" id="post-body">
            <slot />
            {postId && (
              <div class="post-eof" aria-hidden="true">
                <span class="eng-only">[EOF — {postId}] <span class="ok">[exit 0]</span></span>
                <span class="paper-only">End of article</span>
              </div>
            )}
            {editUrl && (
              <p class="edit-link">
                <a href={editUrl} target="_blank" rel="noopener">
                  <span class="eng-only">$ git blame ./{sourcePath}</span>
                  <span class="paper-only">Suggest an edit on GitHub</span>
                </a>
              </p>
            )}
            <slot name="footer" />
          </article>
        </div>
        {showToc && (
          <aside class="toc toc-desktop" aria-label="table of contents">
            <div class="toc-head"><span class="eng-only">&gt; ./contents</span><span class="paper-only">Contents</span></div>
            <ul>
              {tocItems.map((h) => (
                <li class={`d${h.depth}`}>
                  <a href={`#${h.slug}`} data-toc-slug={h.slug}>
                    <span class="text">{h.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )}
        {showToc && <div class="doc-spacer" aria-hidden="true"></div>}
      </div>
    </div>
  </main>
  <script is:inline>
    (function () {
      var COPY = '[copy]';
      var OK = '[ok]';
      var ERR = '[err]';
      document.querySelectorAll('article.prose pre').forEach(function (pre) {
        if (pre.querySelector('.copy-btn')) return;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = COPY;
        btn.setAttribute('aria-label', 'copy code to clipboard');
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          var code = pre.querySelector('code');
          var text = (code ? code.innerText : pre.innerText) || '';
          var done = function (label, ok) {
            btn.textContent = label;
            if (ok) btn.classList.add('ok'); else btn.classList.remove('ok');
            setTimeout(function () { btn.textContent = COPY; btn.classList.remove('ok'); }, 1200);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function () { done(OK, true); }, function () { done(ERR, false); });
          } else {
            done(ERR, false);
          }
        });
        pre.appendChild(btn);
      });

      // Reading progress bar — bound to the post body's scroll progress so
      // it hits 100% when the article ends, not when the page footer ends.
      var bar = document.getElementById('reading-progress');
      var body = document.getElementById('post-body');
      if (bar && body) {
        var fill = bar.firstElementChild;
        var ticking = false;
        var update = function () {
          var rect = body.getBoundingClientRect();
          var vh = window.innerHeight || document.documentElement.clientHeight;
          var total = rect.height - vh;
          var passed = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
          var pct = total > 0 ? (passed / total) * 100 : 0;
          fill.style.width = pct.toFixed(2) + '%';
          ticking = false;
        };
        var schedule = function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(update);
        };
        window.addEventListener('scroll', schedule, { passive: true });
        window.addEventListener('resize', schedule);
        update();
      }

      // Mobile TOC collapses after a link tap so navigation feels snappy.
      var mtoc = document.getElementById('toc-mobile');
      if (mtoc) {
        mtoc.querySelectorAll('a[data-toc-slug]').forEach(function (a) {
          a.addEventListener('click', function () { mtoc.removeAttribute('open'); });
        });
      }

      // Right-rail TOC: highlight the section currently in view.
      var tocLinks = document.querySelectorAll('.toc a[data-toc-slug]');
      if (tocLinks.length && 'IntersectionObserver' in window) {
        var bySlug = {};
        tocLinks.forEach(function (a) { bySlug[a.getAttribute('data-toc-slug')] = a; });
        var headings = Array.prototype.filter.call(
          document.querySelectorAll('article.prose h2[id], article.prose h3[id]'),
          function (h) { return bySlug[h.id]; }
        );
        var visible = new Set();
        var setActive = function (slug) {
          tocLinks.forEach(function (a) { a.classList.toggle('active', a.getAttribute('data-toc-slug') === slug); });
        };
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) visible.add(e.target.id); else visible.delete(e.target.id);
          });
          // Pick the first heading in document order that's currently visible.
          for (var i = 0; i < headings.length; i++) {
            if (visible.has(headings[i].id)) { setActive(headings[i].id); return; }
          }
        }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
        headings.forEach(function (h) { io.observe(h); });
      }
    })();
  </script>
</Base>
