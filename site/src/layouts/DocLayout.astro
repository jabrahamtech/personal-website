---
import Base from './Base.astro';

interface Crumb { href?: string; label: string }

interface Props {
  title: string;
  description: string;
  promptPath: string;
  crumbs: Crumb[];
  metaRow?: { label: string; value: string }[];
  tags?: string[];
}

const { title, description, promptPath, crumbs, metaRow, tags } = Astro.props;
---
<Base title={title} description={description}>
  <main id="content" class="doc">
    <div class="wrap">
      <div class="crumbs">
        {crumbs.map((c, i) => (
          <>
            {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
            {i < crumbs.length - 1 && <span class="sep">/</span>}
          </>
        ))}
      </div>
      <div class="post-prompt">&gt; {promptPath}</div>
      <h1>{title.replace(/ — Jonathan Abraham$/, '')}</h1>
      {metaRow && (
        <div class="meta-row">
          {metaRow.map((m) => <span><b>{m.label}</b> {m.value}</span>)}
        </div>
      )}
      {tags && tags.length > 0 && (
        <div style="margin:0 0 24px">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}

      <article class="prose">
        <slot />
        <slot name="footer" />
      </article>
    </div>
  </main>
</Base>
